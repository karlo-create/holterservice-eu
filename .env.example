# Holterservice — environment variables
# Copy to `.env` for local development. Configure the same vars in
# Vercel project settings for production (Production + Preview).
#
# All `PUBLIC_*` variables are exposed to client-side JS at build time.
# Everything else stays server-only.

# ── Resend (VEY-170 — partner inquiry email) ─────────────────────────
# Required for /api/partner-inquiry to actually send mail. Without it
# the endpoint returns 503 + a Croatian fallback message.
RESEND_API_KEY=

# Recipient of partner-inquiry notifications. Default:
# partneri@holterservice.eu (set in the API route, but overridable here).
PARTNER_INQUIRY_TO=partneri@holterservice.eu

# `from` address for both notification and autoresponder emails.
# Must be a verified sender on your Resend domain.
PARTNER_INQUIRY_FROM=Holterservice <upiti@holterservice.eu>

# ── Cal.com (calendar booking on /za-partnere/hvala + autoresponder) ─
# Public — embedded in client HTML and outgoing emails.
# Founder swaps this to the real 15-min discovery event once Cal.com is set up.
PUBLIC_CAL_LINK=https://cal.com/holterservice

# ── Plausible analytics (default per VEY-170) ────────────────────────
# Leave empty to disable analytics entirely (dev / preview).
# In production, set to `holterservice.eu` after creating the site
# in Plausible.
PUBLIC_PLAUSIBLE_DOMAIN=

# Override only if self-hosting Plausible. Default is plausible.io.
# PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
