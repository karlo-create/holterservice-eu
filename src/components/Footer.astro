---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <!-- Brand col -->
    <div class="footer-col footer-col--brand">
      <div class="brand">
        <svg class="brand-ecg" width="20" height="14" viewBox="0 0 22 16" fill="none" aria-hidden="true">
          <path d="M0 8H4L5.5 2L7.5 14L9.5 5L11 11H14L15 8H22" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Holterservice</span>
      </div>
      <p class="footer-tag">
        Specijalistički Holter EKG nalaz iz vrhunske ustanove —
        dostupan u partnerskim klinikama diljem Hrvatske.
      </p>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Stranice</p>
      <ul>
        <li><a href="/usluga">Usluga</a></li>
        <li><a href="/za-partnere">Za partnere</a></li>
        <li><a href="/za-pacijente">Za pacijente</a></li>
        <li><a href="/partneri">Partneri</a></li>
        <li><a href="/o-nama">O nama</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Pravne informacije</p>
      <ul>
        <li><a href="/privatnost">Politika privatnosti</a></li>
        <li><a href="/kolacici">Kolačići</a></li>
        <li><a href="/impressum">Impressum</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Kontakt</p>
      <ul>
        {/* PLACEHOLDER: add phone/address when founder confirms — for now only email */}
        <li><a href="mailto:info@holterservice.eu">info@holterservice.eu</a></li>
      </ul>
    </div>
  </div>

  {/*
    EU visibility banner (VEY-175/VEY-181). Required on every page per EU
    2021-2027 visual identity rules. Flag isolated (own row), in EU colours
    (#003399 + #FFCC00), 1.5:1 aspect, ≥24px height. Wording confirmed:
    "Sufinancira Europska unija" — project is co-financed (~31.28% EU share)
    via NPOO. Detailed project info lives on /eu-projekt.
  */}
  <div class="footer-eu" aria-label="Sufinancira Europska unija">
    <div class="container footer-eu-inner">
      <a href="/eu-projekt" class="footer-eu-link">
        <img
          src="/eu-flag.svg"
          alt="Zastava Europske unije"
          width="42"
          height="28"
          class="footer-eu-flag"
          loading="lazy"
        />
        <span class="footer-eu-text">Sufinancira Europska unija</span>
        <span class="footer-eu-cta" aria-hidden="true">Saznajte više o projektu →</span>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-meta">
      <small>&copy; {year} Holterservice. Sva prava pridržana.</small>
      <small class="footer-legal-links">
        <a href="/privatnost">Privatnost</a>
        <a href="/kolacici">Kolačići</a>
        <a href="/impressum">Impressum</a>
        <a href="/eu-projekt">EU projekt</a>
      </small>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark-bg);
    color: var(--color-dark-fg-muted);
    font-size: var(--text-sm);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-block: var(--space-16);
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--space-12);
      padding-block: var(--space-20);
    }
  }

  /* Brand */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-dark-fg);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: -0.015em;
    margin-bottom: var(--space-4);
  }

  /* Gold is used ONLY here — the micro-accent for the footer ECG mark */
  .brand-ecg { color: var(--color-gold); }

  .footer-tag {
    max-width: 24rem;
    color: var(--color-dark-fg-muted);
    line-height: var(--leading-normal);
    font-size: var(--text-sm);
    margin: 0;
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-dark-fg);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  ul a {
    color: var(--color-dark-fg-muted);
    text-decoration: none;
    display: block;
    padding-block: 0.15rem;
    transition: color 150ms ease;
    font-size: var(--text-sm);
  }

  ul a:hover { color: var(--color-dark-fg); }

  /* EU visibility banner (VEY-175) — isolated row above the bottom bar */
  .footer-eu {
    border-top: 1px solid var(--color-dark-border);
    background: rgba(255, 255, 255, 0.02);
  }

  .footer-eu-inner {
    padding-block: var(--space-4);
  }

  .footer-eu-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    color: var(--color-dark-fg);
    text-decoration: none;
    font-size: var(--text-sm);
    padding: var(--space-2) 0;
    transition: color 150ms ease;
  }

  .footer-eu-link:hover { color: var(--color-dark-fg); }
  .footer-eu-link:hover .footer-eu-cta { text-decoration: underline; }

  .footer-eu-flag {
    /* 1.5:1 ratio, 28px height ≈ 1cm at typical screen DPI; isolated by gap */
    width: 42px;
    height: 28px;
    display: block;
    flex-shrink: 0;
    border-radius: 2px;
  }

  .footer-eu-text {
    font-weight: 600;
    color: var(--color-dark-fg);
  }

  .footer-eu-cta {
    color: var(--color-dark-fg-muted);
    margin-left: auto;
    font-size: var(--text-xs);
  }

  @media (max-width: 480px) {
    .footer-eu-cta { margin-left: 0; }
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-dark-border);
  }

  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-5);
    color: var(--color-dark-fg-muted);
    font-size: var(--text-xs);
    opacity: 0.65;
  }

  .footer-legal-links {
    display: flex;
    gap: var(--space-5);
  }

  .footer-legal-links a {
    color: inherit;
    text-decoration: none;
  }

  .footer-legal-links a:hover { opacity: 1; text-decoration: underline; }
</style>
