---
/**
 * CroatiaMap: inline SVG of Croatia with partner pins.
 *
 * Receives a list of pins with lat/lng/label/slug. Projects coordinates onto
 * the SVG viewport using a calibrated linear projection matched to the
 * detailed HR outline below.
 *
 * Pins:
 *   - hover/focus → popup with name + city + service chips
 *   - click       → scrolls to <li id={slug}> in the partner list
 *
 * The Croatia outline is a detailed geographic path (mainland + coast + main
 * islands) lifted from the internal prototype `ustanove-njega-hrvatska.html`
 * (640x427 viewBox, single `<path>` inside a `translate(0,427) scale(0.1,-0.1)`
 * group so SVG y can grow downward while the source data is stored y-up at 10x
 * scale). The projection below is the calibrated lon/lat → pixel mapping from
 * that prototype so pin coordinates line up with the rendered outline.
 */

interface Pin {
  slug: string;
  name?: string;
  city: string;
  region?: string;
  coordinates: { lat: number; lng: number };
  /** When true, the pin is a "city marker" only (no real partner yet). */
  placeholder?: boolean;
  /** Service keys offered by this partner (canonical-ordered). */
  services?: string[];
  /** Display labels matching `services` (precomputed by caller). */
  serviceLabels?: string[];
  /**
   * Per-service classification matching `services`: 'universal' (Poliklinika
   * platform service available to every patient regardless of partner) or
   * 'partner' (offered by this specific partner). Used to label chips in the
   * popup so the user can tell platform-wide vs partner-specific apart.
   */
  serviceFlags?: Array<'universal' | 'partner'>;
}

interface Props {
  pins: Pin[];
}

const { pins } = Astro.props as Props;

// Calibrated projection from the prototype: lon/lat → pixel coords in a 640x427
// viewBox. Calibrated against the rendered outline; do not modify without also
// updating the SVG path.
const VIEW_W = 640;
const VIEW_H = 427;
const X0 = 164;
const X1 = 475;
const Y0 = 59;
const Y1 = 362;
const LNG_MIN = 13.49;
const LNG_MAX = 19.45;
const LAT_MIN = 42.39;
const LAT_MAX = 46.55;

const project = (lng: number, lat: number): { x: number; y: number } => {
  const x = X0 + ((lng - LNG_MIN) / (LNG_MAX - LNG_MIN)) * (X1 - X0);
  const y = Y0 + ((LAT_MAX - lat) / (LAT_MAX - LAT_MIN)) * (Y1 - Y0);
  return { x, y };
};

const projectedPins = pins.map((p) => ({
  ...p,
  ...project(p.coordinates.lng, p.coordinates.lat),
}));
---

<figure class="croatia-map" aria-label="Mapa Hrvatske s lokacijama partnerskih klinika">
  <div class="croatia-map-frame">
    <svg
      viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-labelledby="croatia-map-title croatia-map-desc"
    >
      <title id="croatia-map-title">Mapa Hrvatske: lokacije partnera</title>
      <desc id="croatia-map-desc">
        Detaljna mapa Hrvatske s pinovima na lokacijama partnerskih klinika.
        Hover ili klik na pin prikazuje partnera i usluge koje nudi.
      </desc>

      {/*
        Detailed Croatia outline (mainland + coast + main islands).
        Source: internal prototype `ustanove-njega-hrvatska.html` (single SVG path
        authored by the project; no external license attribution required).
        The path coordinates live in a y-up, 10x-scaled space; the wrapping
        transform converts them into the standard 640x427 viewBox.
      */}
      <g class="hr-land-group" transform="translate(0,427) scale(0.1,-0.1)">
        <path class="hr-shape" d="M3130 3693 c-24 -9 -69 -54 -65 -67 2 -6 6 -24 9 -39 6 -25 4 -27 -11 -18 -21 11 -70 3 -80 -13 -4 -6 -8 -17 -8 -25 0 -8 -7 -17 -15 -21 -8 -4 -25 -12 -37 -18 -13 -7 -31 -12 -42 -12 -10 0 -24 -7 -31 -15 -7 -8 -24 -15 -38 -15 -14 0 -38 -12 -54 -27 -36 -34 -38 -80 -5 -111 21 -20 22 -28 17 -79 -4 -32 -5 -63 -3 -69 2 -7 -17 -14 -49 -17 -34 -4 -58 -13 -69 -25 -8 -11 -26 -23 -40 -27 -13 -4 -34 -17 -47 -28 l-22 -21 25 -26 c25 -26 25 -27 6 -44 -16 -15 -18 -23 -9 -46 5 -16 16 -34 24 -41 13 -11 10 -14 -17 -26 -42 -17 -59 -16 -83 5 -12 10 -38 24 -60 31 -35 12 -40 11 -58 -7 -20 -20 -20 -20 -54 2 -18 11 -33 27 -34 33 0 7 -9 18 -20 25 -11 7 -20 22 -20 34 0 12 -7 27 -16 34 -20 17 -35 3 -72 -70 l-27 -55 -65 0 c-36 0 -71 -4 -78 -9 -9 -5 -29 -2 -53 9 -31 14 -42 15 -53 6 -8 -7 -12 -19 -9 -26 7 -19 -44 -31 -68 -16 -10 6 -36 11 -58 11 -21 0 -44 6 -50 14 -17 20 -49 26 -60 12 -14 -17 2 -119 22 -144 5 -7 11 -38 13 -70 3 -73 14 -100 64 -163 30 -39 38 -55 30 -64 -8 -10 -6 -17 9 -27 12 -8 19 -17 16 -20 -9 -9 40 -46 72 -53 34 -7 45 3 49 43 3 29 28 58 63 75 20 9 27 21 29 47 1 19 8 45 14 57 l11 22 17 -22 c9 -12 26 -41 37 -65 19 -39 19 -42 3 -37 -25 8 -41 -17 -34 -54 4 -17 11 -34 15 -37 5 -3 9 -15 9 -28 0 -12 5 -27 10 -32 8 -8 6 -15 -5 -24 -8 -7 -15 -19 -15 -27 0 -12 -3 -13 -13 -4 -11 8 -18 6 -32 -9 -17 -19 -17 -21 0 -40 14 -16 21 -17 32 -8 8 6 11 18 8 25 -3 9 0 13 7 11 7 -3 15 -15 17 -29 1 -13 24 -45 49 -71 41 -42 48 -46 61 -33 13 13 12 18 -10 42 -49 54 -52 61 -26 56 36 -7 49 17 31 53 -20 37 -33 211 -15 200 19 -12 44 14 30 30 -7 9 -8 14 -1 14 5 0 12 -7 15 -14 3 -8 21 -22 39 -32 18 -9 43 -25 55 -36 12 -11 26 -17 32 -13 7 4 11 -7 11 -29 0 -33 -2 -35 -19 -24 -11 7 -19 16 -18 21 1 5 -6 14 -16 20 -15 10 -22 7 -42 -18 -22 -27 -23 -31 -8 -47 9 -10 24 -18 33 -18 9 0 27 -11 40 -25 12 -13 27 -22 31 -19 4 2 13 -4 19 -15 19 -36 -11 -37 -40 -2 -23 29 -28 31 -39 18 -10 -13 -5 -25 33 -73 25 -32 43 -62 40 -66 -3 -5 -1 -15 6 -23 8 -10 8 -15 0 -20 -8 -5 -6 -13 6 -26 13 -15 20 -16 31 -7 11 9 20 6 41 -15 19 -19 22 -27 11 -27 -29 0 -40 -22 -22 -42 9 -10 22 -18 29 -18 15 0 36 -34 27 -44 -3 -3 1 -14 9 -23 28 -33 31 -48 5 -24 -22 20 -29 22 -42 11 -11 -9 -12 -16 -4 -26 6 -7 8 -18 4 -25 -5 -7 -24 6 -55 36 -41 40 -48 44 -60 30 -11 -13 -6 -22 31 -64 24 -27 56 -67 71 -89 33 -50 81 -77 99 -56 10 12 7 20 -16 44 -23 24 -26 32 -15 45 7 8 16 12 22 9 5 -3 16 0 24 7 12 10 18 9 32 -6 14 -16 14 -17 1 -7 -13 10 -19 9 -30 -4 -11 -14 -7 -22 34 -60 41 -40 49 -43 66 -32 18 11 23 10 35 -7 9 -11 14 -25 11 -31 -5 -16 51 -68 64 -60 6 4 18 2 28 -3 10 -5 26 -12 35 -15 10 -3 15 -11 12 -19 -8 -21 23 -42 40 -28 20 16 30 -3 15 -27 -7 -11 -9 -26 -5 -33 24 -51 45 -74 74 -81 18 -5 30 -13 27 -17 -2 -5 2 -14 10 -21 20 -17 48 5 40 31 -7 20 9 26 20 9 9 -15 71 -12 84 3 8 10 7 17 -1 25 -8 8 -8 12 -1 12 6 0 16 -7 23 -15 7 -8 22 -15 33 -15 11 0 34 -11 51 -24 18 -13 40 -26 51 -29 11 -4 -13 -5 -52 -3 -71 3 -104 -8 -85 -29 4 -5 -8 3 -25 17 -45 36 -72 44 -90 25 -9 -8 -13 -20 -9 -25 8 -13 106 -64 106 -56 0 4 8 0 18 -8 9 -9 31 -23 47 -31 l30 -16 -30 -1 c-17 0 -41 -7 -53 -16 -31 -22 -15 -39 57 -61 31 -9 65 -25 77 -35 25 -22 38 -23 54 -3 10 11 35 15 110 15 102 0 134 12 107 39 -6 7 6 2 28 -10 38 -22 81 -61 135 -125 l25 -29 -30 26 c-43 37 -108 62 -163 63 -26 1 -52 5 -59 9 -11 7 -28 -9 -28 -28 0 -18 -84 -29 -119 -17 -18 7 -39 12 -48 12 -19 0 -41 -24 -30 -34 4 -4 7 -13 7 -19 0 -19 57 -40 105 -39 25 1 76 1 114 2 74 0 104 13 85 36 -18 22 5 16 45 -11 20 -14 42 -25 47 -25 6 0 18 -9 27 -19 18 -20 148 -65 162 -56 5 3 11 1 14 -4 3 -5 16 -7 29 -3 20 5 21 4 8 -12 -13 -15 -12 -20 7 -39 16 -16 25 -18 33 -10 13 13 54 -8 77 -39 6 -9 26 -19 42 -23 17 -4 30 -13 30 -20 0 -7 31 -36 69 -64 78 -56 93 -54 82 14 -4 26 -13 43 -28 50 -11 6 -27 16 -34 22 -8 6 -25 14 -39 18 -27 8 -146 89 -192 130 -16 13 -28 30 -28 38 0 39 -81 68 -111 41 -11 -9 -19 -14 -19 -10 0 4 10 16 23 26 l22 19 -20 38 c-11 20 -40 53 -65 71 -25 19 -48 42 -51 51 -4 9 -17 25 -29 36 -36 32 -52 72 -44 111 5 28 2 40 -17 60 -13 14 -34 24 -51 24 -22 0 -51 21 -132 98 -57 53 -107 106 -111 117 -16 41 -160 204 -182 205 -10 0 -22 16 -71 94 -7 12 -11 39 -9 63 3 25 0 47 -7 52 -7 6 -18 32 -25 60 -13 52 -42 88 -61 76 -9 -6 -9 -2 0 15 10 19 6 27 -41 75 -41 42 -56 52 -70 45 -12 -7 -21 -4 -33 9 -20 22 -20 30 -1 51 12 14 13 23 5 41 -8 18 -7 52 2 129 l13 105 47 3 c41 3 48 0 65 -24 10 -15 36 -47 58 -71 32 -35 48 -45 75 -46 32 -2 37 2 60 43 14 25 34 60 45 78 22 36 28 37 118 11 l49 -14 27 34 c20 24 32 32 42 25 8 -5 20 -9 27 -10 7 -1 28 -16 47 -33 42 -37 79 -48 100 -31 13 10 21 10 43 0 15 -7 36 -14 47 -16 11 -2 34 -6 51 -9 21 -5 34 -2 43 9 22 26 54 19 85 -20 23 -30 33 -35 55 -29 14 3 37 18 50 32 19 22 26 24 40 15 48 -35 60 -36 89 -9 24 23 29 24 46 11 11 -8 30 -14 42 -14 12 0 27 -7 34 -16 26 -30 50 -37 71 -18 15 14 21 14 34 4 8 -7 15 -9 15 -5 0 4 13 -7 29 -24 20 -21 27 -38 24 -52 -4 -13 4 -30 23 -50 42 -44 86 -40 147 12 34 30 45 45 38 52 -6 6 -11 25 -12 42 0 16 -4 39 -8 50 -12 30 14 42 82 39 65 -4 87 6 87 39 0 33 -29 56 -91 73 -39 11 -64 24 -74 40 -8 13 -22 24 -30 24 -18 0 -19 12 -3 28 9 9 9 15 0 24 -9 9 -6 14 11 22 33 17 32 41 -4 67 -26 18 -35 20 -50 11 -16 -10 -19 -9 -19 4 0 9 8 29 17 45 16 26 16 29 0 47 -9 10 -17 26 -17 34 0 9 -7 21 -15 28 -18 15 -19 32 -3 48 16 16 19 59 5 71 -8 6 -24 3 -48 -8 -25 -12 -42 -15 -53 -9 -28 16 -48 5 -72 -37 -12 -22 -31 -41 -42 -43 -11 -2 -27 -11 -36 -21 -14 -16 -23 -17 -59 -9 -22 5 -46 13 -52 17 -5 5 -54 8 -108 7 -66 -1 -102 3 -109 11 -5 7 -25 17 -44 23 -19 6 -34 17 -34 24 0 7 -13 25 -29 40 -23 22 -40 29 -87 32 -62 4 -59 2 -99 79 -16 31 -27 41 -55 46 -41 9 -128 98 -137 142 -6 30 -46 67 -72 67 -9 0 -29 16 -45 36 -19 25 -34 34 -47 31 -10 -3 -21 -2 -24 3 -6 9 -91 50 -102 49 -5 0 -15 -3 -23 -6z m-992 -963 c38 -17 42 -23 36 -42 -4 -13 -7 -30 -6 -39 0 -9 -13 -29 -29 -45 l-29 -28 0 24 c0 13 -7 32 -17 42 -15 17 -18 17 -34 2 -16 -15 -17 -14 -12 8 25 111 23 109 91 78z m170 -140 c31 -25 65 -105 57 -131 -6 -19 -9 -20 -23 -6 -12 12 -13 19 -4 30 9 11 5 23 -19 55 -17 23 -35 42 -40 42 -5 0 -9 7 -9 15 0 20 10 18 38 -5z m-145 -83 c-6 -9 -43 21 -43 35 0 5 11 1 24 -9 13 -10 22 -22 19 -26z m343 -409 l29 -33 -32 29 c-31 28 -38 36 -30 36 2 0 16 -15 33 -32z m916 -786 c9 -4 44 -40 79 -81 l62 -74 -69 7 c-38 4 -85 7 -105 7 -24 -1 -41 5 -54 19 -18 20 -18 20 23 20 29 0 49 7 69 25 l28 25 -21 18 c-12 9 -30 22 -40 29 -14 9 -15 12 -4 12 8 0 23 -3 32 -7z" />
      </g>

      {/* ── Pins ──────────────────────────────────────────────────────────── */}
      {projectedPins.map((p) => {
        const labelList = p.serviceLabels && p.serviceLabels.length > 0
          ? ` (${p.serviceLabels.join(', ')})`
          : '';
        return (
          <a
            href={`#${p.slug}`}
            class:list={['hr-pin', p.placeholder && 'is-placeholder']}
            data-slug={p.slug}
            data-city={p.city}
            data-name={p.name || ''}
            data-services={(p.serviceLabels || []).join('|')}
            data-service-flags={(p.serviceFlags || []).join('|')}
            aria-label={
              p.name
                ? `${p.name}, ${p.city}${labelList}`
                : `${p.city}${labelList}`
            }
          >
            <circle cx={p.x} cy={p.y} r="14" class="hr-pin-halo" />
            <circle cx={p.x} cy={p.y} r="7" class="hr-pin-dot" />
            <text x={p.x} y={p.y - 14} class="hr-pin-label" text-anchor="middle">
              {p.city}
            </text>
            <title>{p.name ? `${p.name}, ${p.city}${labelList}` : `${p.city}${labelList}`}</title>
          </a>
        );
      })}
    </svg>

    {/* HTML popup overlay positioned absolutely over the SVG. JS positions it
        on hover/focus relative to the figure frame. */}
    <div
      class="croatia-map-popup"
      role="status"
      aria-live="polite"
      data-map-popup
      hidden
    >
      <p class="croatia-map-popup-name" data-popup-name></p>
      <p class="croatia-map-popup-city" data-popup-city></p>
      <div class="croatia-map-popup-services" data-popup-services></div>
      <p class="croatia-map-popup-note" data-popup-note hidden>
        <span class="croatia-map-popup-dot" aria-hidden="true"></span>
        <span>Pruža Poliklinika — dostupno svim pacijentima</span>
      </p>
    </div>
  </div>
  <figcaption class="visually-hidden">
    Mapa Hrvatske s lokacijama partnerskih klinika. Hover ili klik na pin
    prikazuje partnera i usluge koje nudi.
  </figcaption>
</figure>

<script>
  // Smooth-scroll partner pins to the matching card.
  document.querySelectorAll<SVGAElement>('.croatia-map a.hr-pin').forEach((a) => {
    a.addEventListener('click', (e) => {
      const href = a.getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      const target = document.getElementById(href.slice(1));
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      target.classList.add('partner-flash');
      window.setTimeout(() => target.classList.remove('partner-flash'), 1600);
    });
  });

  // Hover/focus popup that surfaces partner + services in HTML (richer than
  // the native SVG <title> tooltip). Pure read-only on dummy data; no
  // external lookups.
  (function initMapPopup() {
    const frame = document.querySelector<HTMLElement>('.croatia-map-frame');
    if (!frame) return;
    const popup = frame.querySelector<HTMLElement>('[data-map-popup]');
    if (!popup) return;
    const nameEl = popup.querySelector<HTMLElement>('[data-popup-name]');
    const cityEl = popup.querySelector<HTMLElement>('[data-popup-city]');
    const servicesEl = popup.querySelector<HTMLElement>('[data-popup-services]');
    const noteEl = popup.querySelector<HTMLElement>('[data-popup-note]');

    function show(anchor: SVGAElement) {
      const name = anchor.getAttribute('data-name') || '';
      const city = anchor.getAttribute('data-city') || '';
      const services = (anchor.getAttribute('data-services') || '')
        .split('|')
        .filter(Boolean);
      const flags = (anchor.getAttribute('data-service-flags') || '')
        .split('|')
        .filter(Boolean);

      if (nameEl) nameEl.textContent = name || city;
      if (cityEl) {
        cityEl.textContent = name && city ? city : '';
        cityEl.hidden = !(name && city);
      }
      let hasUniversal = false;
      if (servicesEl) {
        servicesEl.innerHTML = '';
        if (services.length === 0) {
          servicesEl.hidden = true;
        } else {
          servicesEl.hidden = false;
          services.forEach((label, i) => {
            const isUniversal = flags[i] === 'universal';
            if (isUniversal) hasUniversal = true;
            const chip = document.createElement('span');
            chip.className = 'croatia-map-popup-chip' +
              (isUniversal ? ' croatia-map-popup-chip-universal' : '');
            if (isUniversal) {
              const dot = document.createElement('span');
              dot.className = 'croatia-map-popup-chip-dot';
              dot.setAttribute('aria-hidden', 'true');
              chip.appendChild(dot);
            }
            chip.appendChild(document.createTextNode(label));
            servicesEl.appendChild(chip);
          });
        }
      }
      if (noteEl) noteEl.hidden = !hasUniversal;

      // Position popup relative to the pin's bounding box in the figure frame.
      const frameRect = frame!.getBoundingClientRect();
      const pinRect = anchor.getBoundingClientRect();
      const popupWidth = 240;
      const popupGap = 12;
      let left = pinRect.left + pinRect.width / 2 - frameRect.left - popupWidth / 2;
      const top = pinRect.top - frameRect.top - popupGap;
      // Clamp left within the frame so the popup never escapes the map card.
      left = Math.max(8, Math.min(left, frameRect.width - popupWidth - 8));

      popup!.style.left = left + 'px';
      popup!.style.top = top + 'px';
      popup!.style.width = popupWidth + 'px';
      popup!.hidden = false;
    }

    function hide() {
      popup!.hidden = true;
    }

    const anchors = Array.from(
      document.querySelectorAll<SVGAElement>('.croatia-map a.hr-pin')
    );

    anchors.forEach((a) => {
      a.addEventListener('mouseenter', () => show(a));
      a.addEventListener('mouseleave', hide);
      a.addEventListener('focus', () => show(a));
      a.addEventListener('blur', hide);
    });

    // Hide popup on outside touch / scroll, so it doesn't linger on mobile.
    window.addEventListener('scroll', hide, { passive: true });
    document.addEventListener('touchstart', (e) => {
      const target = e.target as Element | null;
      if (target && target.closest && target.closest('.hr-pin')) return;
      hide();
    }, { passive: true });
  })();
</script>

<style>
  .croatia-map {
    margin: 0;
    width: 100%;
    max-width: 56rem;
    margin-inline: auto;
  }

  .croatia-map-frame {
    position: relative;
    width: 100%;
  }

  .croatia-map svg {
    width: 100%;
    height: auto;
    display: block;
    background: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .hr-shape {
    fill: var(--color-muted, #e5e7eb);
    stroke: var(--color-border);
    stroke-width: 8;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  /* Pin */
  .hr-pin { cursor: pointer; outline: none; }

  .hr-pin-halo {
    fill: var(--color-primary, #1457a4);
    opacity: 0.15;
    transition: opacity 180ms ease, r 180ms ease;
  }

  .hr-pin-dot {
    fill: var(--color-primary, #1457a4);
    stroke: #fff;
    stroke-width: 2;
    transition: r 180ms ease;
  }

  .hr-pin-label {
    fill: var(--color-foreground);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    paint-order: stroke;
    stroke: var(--color-accent);
    stroke-width: 3.5;
    stroke-linejoin: round;
    pointer-events: none;
  }

  .hr-pin:hover .hr-pin-halo,
  .hr-pin:focus .hr-pin-halo {
    opacity: 0.32;
  }

  .hr-pin:hover .hr-pin-dot,
  .hr-pin:focus .hr-pin-dot {
    r: 9;
  }

  .hr-pin.is-placeholder .hr-pin-dot {
    fill: var(--color-muted-foreground, #6b7280);
  }

  .hr-pin.is-placeholder .hr-pin-halo {
    fill: var(--color-muted-foreground, #6b7280);
  }

  /* ── Hover/focus popup ────────────────────────────────────────────── */
  .croatia-map-popup {
    position: absolute;
    transform: translateY(-100%);
    z-index: 5;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    box-shadow: 0 2px 4px rgb(0 0 0 / 0.05), 0 6px 16px rgb(20 87 164 / 0.10);
    pointer-events: none;
    font-family: var(--font-body);
    line-height: 1.35;
  }

  .croatia-map-popup[hidden] {
    display: none;
  }

  .croatia-map-popup-name {
    font-weight: 600;
    color: var(--color-foreground);
    font-size: var(--text-sm);
    margin: 0;
  }

  .croatia-map-popup-city {
    color: var(--color-muted-foreground);
    font-size: var(--text-xs);
    margin: 0.125rem 0 0;
  }

  .croatia-map-popup-services {
    margin-top: var(--space-2);
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .croatia-map-popup-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.125rem 0.4rem;
    border-radius: 9999px;
    border: 1px solid rgba(20, 87, 164, 0.2);
    background: var(--color-primary-light);
    color: var(--color-primary);
    line-height: 1.3;
  }

  .croatia-map-popup-chip-universal {
    border-style: dashed;
  }

  .croatia-map-popup-chip-dot {
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: currentColor;
    display: inline-block;
    flex-shrink: 0;
  }

  .croatia-map-popup-note {
    margin: var(--space-2) 0 0;
    padding-top: var(--space-2);
    border-top: 1px dashed rgba(20, 87, 164, 0.2);
    font-size: 10px;
    color: var(--color-muted-foreground);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    line-height: 1.3;
  }

  .croatia-map-popup-note[hidden] { display: none; }

  .croatia-map-popup-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--color-primary);
    display: inline-block;
    flex-shrink: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
