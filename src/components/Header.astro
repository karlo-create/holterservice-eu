---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const nav = [
  { href: '/usluga', label: 'Usluga' },
  { href: '/za-partnere', label: 'Za partnere' },
  { href: '/za-pacijente', label: 'Za pacijente' },
  { href: '/partneri', label: 'Partneri' },
  { href: '/o-nama', label: 'O nama' },
  { href: '/kontakt', label: 'Kontakt' },
];

const isActive = (href: string) => pathname === href;
---

<header class="site-header">
  <div class="container header-inner">
    <!-- Brand / wordmark -->
    <a href="/" class="brand" aria-label="Holterservice — početna">
      <svg class="brand-ecg" width="20" height="14" viewBox="0 0 22 16" fill="none" aria-hidden="true">
        <path d="M0 8H4L5.5 2L7.5 14L9.5 5L11 11H14L15 8H22" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="brand-text">Holterservice</span>
    </a>

    <!-- Nav -->
    <nav aria-label="Glavna navigacija">
      <input type="checkbox" id="nav-toggle" class="nav-toggle" />
      <label for="nav-toggle" class="nav-toggle-label" aria-label="Otvori izbornik">
        <span></span><span></span><span></span>
      </label>
      <ul class="nav-list">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class={isActive(item.href) ? 'active' : ''}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="nav-cta-item">
          <a href="/za-partnere" class="btn btn-primary nav-cta">Postanite partner</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--header-height);
    gap: var(--space-4);
  }

  /* ── Brand wordmark ───────────────────────────────────────────────────── */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-foreground);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .brand:hover { text-decoration: none; color: var(--color-primary); }
  .brand:hover .brand-ecg { color: var(--color-primary); }

  .brand-ecg {
    color: var(--color-primary);
    transition: color 150ms ease;
  }

  /* ── Hamburger (mobile only) ──────────────────────────────────────────── */
  .nav-toggle { display: none; }

  .nav-toggle-label {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 8px;
    cursor: pointer;
    justify-content: center;
    border-radius: var(--radius-md);
    transition: background 150ms ease;
  }

  .nav-toggle-label:hover { background: var(--color-muted); }

  .nav-toggle-label span {
    display: block;
    height: 2px;
    background: var(--color-foreground);
    border-radius: 1px;
    transition: transform 200ms ease, opacity 150ms ease;
  }

  .nav-toggle:checked ~ .nav-toggle-label span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle:checked ~ .nav-toggle-label span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle:checked ~ .nav-toggle-label span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Nav list — mobile dropdown ───────────────────────────────────────── */
  .nav-list {
    display: none;
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    flex-direction: column;
    list-style: none;
    margin: 0;
    padding: var(--space-3) var(--space-3) var(--space-4);
    gap: 2px;
    box-shadow: var(--shadow-lg);
  }

  .nav-toggle:checked ~ .nav-list { display: flex; }

  .nav-list li { width: 100%; }

  .nav-list a {
    display: block;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    color: var(--color-foreground);
    text-decoration: none;
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0;
  }

  .nav-list a:hover { background: var(--color-muted); color: var(--color-primary); text-decoration: none; }
  .nav-list a.active { background: var(--color-primary-light); color: var(--color-primary); font-weight: 600; }

  .nav-cta-item {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .nav-cta { width: 100%; justify-content: center; }

  /* ── Desktop nav ──────────────────────────────────────────────────────── */
  @media (min-width: 768px) {
    .nav-toggle-label { display: none; }

    .nav-list {
      display: flex !important;
      position: static;
      flex-direction: row;
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 0;
      /* Explicit gap that doesn't depend on CSS variables parsing order */
      gap: 2px;
      align-items: center;
    }

    .nav-list li { width: auto; }

    .nav-list a {
      display: block;
      padding: 0.5rem 0.75rem;
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--color-muted-foreground);
      white-space: nowrap;
    }

    .nav-list a:hover { background: var(--color-muted); color: var(--color-foreground); text-decoration: none; }
    .nav-list a.active { color: var(--color-primary); background: var(--color-primary-light); }

    .nav-cta-item {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
      margin-left: var(--space-3);
    }

    .nav-cta { width: auto; }
  }

  /* Keep the CTA button white on its blue fill even when nested under .nav-list
     (overrides the desktop .nav-list a muted color which has higher specificity
     than the base .btn-primary rule). */
  .nav-list a.btn-primary,
  .nav-list a.nav-cta {
    color: var(--color-primary-contrast);
  }
  .nav-list a.btn-primary:hover,
  .nav-list a.nav-cta:hover {
    color: var(--color-primary-contrast);
    background: var(--color-primary-hover, var(--color-primary));
  }
</style>
