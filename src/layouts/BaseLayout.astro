---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  type?: 'website' | 'article';
}

const { title, description, path, ogImage, type } = Astro.props;

// Plausible analytics — only enabled when NEXT_PUBLIC_PLAUSIBLE_DOMAIN is set
// (e.g. holterservice.eu). Naming follows spec from VEY-177 even though we
// run on Astro, so the founder can re-use it if/when stack changes.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN
  || import.meta.env.NEXT_PUBLIC_PLAUSIBLE_DOMAIN;
---

<!doctype html>
<html lang="hr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1457a4" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Fonts: Source Serif 4 Variable + Inter Variable — self-hosted via fontsource (imported in global.css) -->
    <Seo title={title} description={description} path={path} ogImage={ogImage} type={type} />
    {plausibleDomain && (
      <>
        <script
          defer
          is:inline
          data-domain={plausibleDomain}
          src="https://plausible.io/js/script.js"
        ></script>
        <script is:inline>
          window.plausible = window.plausible || function () {
            (window.plausible.q = window.plausible.q || []).push(arguments);
          };
        </script>
      </>
    )}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Preskoči na sadržaj</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    {plausibleDomain && (
      <script is:inline>
        (function () {
          var p = function (name, props) {
            if (typeof window.plausible !== 'function') return;
            window.plausible(name, props ? { props: props } : undefined);
          };

          // Email/phone click tracking
          document.addEventListener('click', function (e) {
            var t = e.target;
            if (!(t instanceof Element)) return;
            var a = t.closest('a');
            if (!a) return;
            var href = a.getAttribute('href') || '';
            if (href.indexOf('mailto:') === 0) {
              p('partner_email_click', { email: href.replace('mailto:', '') });
            } else if (href.indexOf('tel:') === 0) {
              p('partner_phone_click', { phone: href.replace('tel:', '') });
            } else if (
              href.indexOf('cal.com') !== -1 ||
              href.indexOf('calendly.com') !== -1
            ) {
              p('partner_calendar_book_click', { href: href });
            }
            // Patient -> partner card click on /za-pacijente
            if (a.dataset && a.dataset.event === 'patient_partner_card_click') {
              p('patient_partner_card_click', { partner: a.dataset.partner || '' });
            }
          }, { passive: true });

          // Partner form view + submit tracking
          var forms = document.querySelectorAll('form[data-plausible-form="partner"]');
          forms.forEach(function (form) {
            if ('IntersectionObserver' in window) {
              var seen = false;
              var io = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting && !seen) {
                    seen = true;
                    p('partner_form_view');
                    io.disconnect();
                  }
                });
              }, { threshold: 0.25 });
              io.observe(form);
            } else {
              p('partner_form_view');
            }
            form.addEventListener('submit', function () {
              // mailto: form — we can't observe true success/error from the
              // mail client, so only `submit_attempt` fires here. Once a real
              // POST endpoint exists, fire `partner_form_submit_success` and
              // `partner_form_submit_error` from the response handler.
              p('partner_form_submit_attempt');
            });
          });
        })();
      </script>
    )}
  </body>
</html>
