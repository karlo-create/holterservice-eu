---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Holter EKG nalaz iz vrhunske ustanove — bez putovanja';
const description =
  'Holterservice: dr. Obad daje Holter EKG uređaje partnerskim klinikama i osobno potpisuje specijalistički nalaz. Pacijenti u udaljenim područjima dobivaju vrhunsku kardiološku obradu bez putovanja u Split ili Zagreb.';

const medicalBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'Holterservice',
  description,
  url: 'https://holterservice.eu',
  medicalSpecialty: 'Cardiovascular',
  areaServed: { '@type': 'Country', name: 'Hrvatska' },
  availableService: {
    '@type': 'MedicalProcedure',
    name: 'Holter EKG monitoring i specijalistički nalaz',
    procedureType: 'https://schema.org/DiagnosticProcedure',
  },
  // PLACEHOLDER: real address/contact when founder confirms.
};
---

<BaseLayout title={title} description={description} path="/">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(medicalBusinessJsonLd)}
    slot="head"
  />

  <!-- HERO — dark navy, full authority -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="eyebrow-row">
        <svg class="ecg-pulse" width="32" height="20" viewBox="0 0 32 20" fill="none" aria-hidden="true">
          <path d="M0 10H8L10 2L13 18L16 7L18 13H24L26 10H32" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <p class="eyebrow">Holter EKG · Specijalistički nalaz</p>
      </div>
      <h1>Vrhunski kardiološki nalaz — bez putovanja u Split ili Zagreb.</h1>
      <p class="lede">
        Dr. Obad, kardiolog iz provjerene ustanove, daje Holter EKG uređaje partnerskim
        klinikama u manjim mjestima i otocima. Vaš nalaz osobno očita i potpiše
        specijalist — gdje god da se nalazite.
      </p>
      <div class="cta-row">
        <a href="/za-partnere" class="btn btn-primary-invert">Postanite partner</a>
        <a href="/za-pacijente" class="btn btn-secondary-invert">Tražim nalaz u svom mjestu</a>
      </div>
    </div>

    <!-- Decorative ECG line across the bottom -->
    <div class="hero-ecg" aria-hidden="true">
      <svg viewBox="0 0 1200 60" fill="none" preserveAspectRatio="none">
        <path d="M0 30 H200 L210 10 L225 50 L240 5 L255 55 L265 30 H400 L410 15 L420 45 L430 30 H600 L612 8 L625 52 L635 20 L642 38 L648 30 H800 L810 12 L820 48 L830 25 L837 35 L843 30 H1200" stroke="rgba(196,154,60,0.4)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- VALUE PROPOSITION — 3 pillars on warm background -->
  <section class="section section-muted">
    <div class="container">
      <div class="value-grid">
        <div class="value">
          <div class="value-num">01</div>
          <h2>Specijalistički nalaz</h2>
          <p>
            Svaki snimak osobno očita i potpiše dr. Obad. Bez delegiranja, bez automatskih
            izvještaja — kvaliteta kao u referentnoj ustanovi.
          </p>
        </div>
        <div class="value">
          <div class="value-num">02</div>
          <h2>Dostupnost u manjim mjestima</h2>
          <p>
            Uređaji su raspoređeni u partnerskim klinikama u područjima u kojima
            kardiološka obrada inače znači cjelodnevni put. Lastovo, Virovitica i drugi.
          </p>
        </div>
        <div class="value">
          <div class="value-num">03</div>
          <h2>Edukacija osoblja</h2>
          <p>
            Obučavamo medicinsko i ne-medicinsko osoblje partnera za ispravno postavljanje
            i skidanje uređaja. Po potrebi izdajemo certifikat osposobljenosti.
            {/* PLACEHOLDER: točan naziv i opseg certifikata */}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS — clean white, editorial numbered list -->
  <section class="section">
    <div class="container how-it-works">
      <div class="section-header">
        <p class="section-label">Tijek pretrage</p>
        <h2>Kako proces izgleda</h2>
      </div>
      <ol class="steps">
        <li>
          <div class="step-marker">
            <span class="step-num" aria-hidden="true">1</span>
          </div>
          <div class="step-content">
            <h3>Pacijent dolazi u partnersku kliniku</h3>
            <p>
              Osoblje partnera postavlja Holter EKG uređaj. Pacijent ga nosi 24 sata
              tijekom svog uobičajenog dana.
            </p>
          </div>
        </li>
        <li>
          <div class="step-marker">
            <span class="step-num" aria-hidden="true">2</span>
          </div>
          <div class="step-content">
            <h3>Snimak se šalje dr. Obadu</h3>
            <p>
              Nakon skidanja, podatci se sigurno prosljeđuju u ustanovu na očitanje.
            </p>
          </div>
        </li>
        <li>
          <div class="step-marker">
            <span class="step-num" aria-hidden="true">3</span>
          </div>
          <div class="step-content">
            <h3>Specijalist potpisuje nalaz</h3>
            <p>
              Pacijent putem partnera preuzima službeni Holter EKG nalaz potpisan od
              specijaliste kardiologije.
            </p>
          </div>
        </li>
      </ol>
      <p class="how-cta">
        <a href="/usluga">Saznajte više o usluzi →</a>
      </p>
    </div>
  </section>

  <!-- PARTNER CTA — dark navy, closes the page with authority -->
  <section class="section partner-cta-section">
    <div class="container partner-cta">
      <div class="partner-cta-body">
        <p class="section-label-invert">Za ordinacije i klinike</p>
        <h2>Vodite kliniku u manjem mjestu?</h2>
        <p>
          Ponudite pacijentima specijalistički Holter EKG nalaz bez slanja u udaljena
          središta. Mi dostavljamo opremu, obučavamo osoblje i preuzimamo očitanje.
        </p>
      </div>
      <div class="partner-cta-action">
        <a href="/za-partnere" class="btn btn-primary-invert">Detalji za partnere</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    background: var(--color-dark-bg);
    color: var(--color-dark-fg);
    padding-block: var(--space-24);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero { padding-block: var(--space-32); }
  }

  .hero-inner { max-width: 54rem; position: relative; z-index: 1; }

  /* Subtle background texture — concentric rings suggest precision instruments */
  .hero::before {
    content: '';
    position: absolute;
    right: -10%;
    top: -20%;
    width: 60%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(30, 69, 118, 0.6) 0%, transparent 70%);
    pointer-events: none;
  }

  .eyebrow-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .ecg-pulse {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .eyebrow {
    color: var(--color-gold);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }

  .hero h1 {
    color: var(--color-dark-fg);
    font-weight: 700;
    letter-spacing: -0.025em;
    font-size: var(--text-3xl);
    line-height: 1.1;
    margin-bottom: var(--space-5);
  }

  @media (min-width: 768px) {
    .hero h1 { font-size: var(--text-5xl); }
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-dark-fg-muted);
    max-width: 38rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-10);
  }

  /* ECG decorative line at hero bottom */
  .hero-ecg {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    pointer-events: none;
  }

  .hero-ecg svg { width: 100%; height: 100%; }

  /* ─── Value grid ─────────────────────────────────────────────────────── */
  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .value-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .value {
    border-top: 2px solid var(--color-primary);
    padding-top: var(--space-5);
  }

  .value-num {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .value h2 {
    margin-bottom: var(--space-3);
    font-size: var(--text-xl);
    color: var(--color-foreground);
  }

  .value p { color: var(--color-muted-foreground); font-size: var(--text-base); }

  /* ─── How it works ───────────────────────────────────────────────────── */
  .section-header {
    margin-bottom: var(--space-10);
  }

  .section-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .section-label-invert {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-3);
  }

  .how-it-works h2 { margin: 0; }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    max-width: 44rem;
  }

  .steps li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-5);
    align-items: start;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .steps li:first-child { border-top: 1px solid var(--color-border); }

  .step-marker {
    padding-top: 0.15rem;
  }

  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .step-content h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    color: var(--color-foreground);
  }

  .step-content p { color: var(--color-muted-foreground); margin: 0; }

  .how-cta {
    margin-top: var(--space-8);
  }

  .how-cta a {
    font-weight: 500;
    font-size: var(--text-base);
    color: var(--color-primary);
    text-decoration: none;
  }

  .how-cta a:hover { text-decoration: underline; }

  /* ─── Partner CTA — dark ─────────────────────────────────────────────── */
  .partner-cta-section {
    background: var(--color-dark-bg);
    color: var(--color-dark-fg);
    margin-top: 0;
  }

  .partner-cta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .partner-cta {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-12);
    }
    .partner-cta-action { justify-self: end; }
  }

  .partner-cta-body h2 {
    color: var(--color-dark-fg);
    margin-bottom: var(--space-3);
    margin-top: var(--space-2);
  }

  .partner-cta-body p {
    color: var(--color-dark-fg-muted);
    margin: 0;
  }
</style>
