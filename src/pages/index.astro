---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Holter EKG nalaz iz referentne ustanove, bez putovanja';
const description =
  'Holterservice opskrbljuje partnerske klinike Holter EKG uređajima i specijalističkim nalazom, kako bi pacijenti dobili kardiološku dijagnostiku bez putovanja u Split ili Zagreb.';

const medicalBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'Holterservice',
  description,
  url: 'https://holterservice.eu',
  medicalSpecialty: 'Cardiovascular',
  areaServed: { '@type': 'Country', name: 'Hrvatska' },
  availableService: {
    '@type': 'MedicalProcedure',
    name: 'Holter EKG monitoring i specijalistički nalaz',
    procedureType: 'https://schema.org/DiagnosticProcedure',
  },
  // PLACEHOLDER: real address/contact when founder confirms.
};
---

<BaseLayout title={title} description={description} path="/">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(medicalBusinessJsonLd)}
    slot="head"
  />

  <!-- ═══ HERO: light editorial, typographic authority ══════════════════ -->
  <section class="hero">
    <!-- Subtle ECG waveform background -->
    <div class="hero-bg-wave" aria-hidden="true">
      <svg viewBox="0 0 1200 200" fill="none" preserveAspectRatio="none">
        <path d="M0 100 H220 L235 40 L260 160 L280 20 L300 170 L315 100 H520 L535 55 L550 145 L565 75 L577 120 L585 100 H800 L816 35 L835 165 L850 60 L862 130 L870 100 H1200" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <div class="container hero-inner">
      <!-- Left: editorial copy -->
      <div class="hero-copy">
        <!-- Credential badge: trust signal above the headline -->
        <div class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Specijalistički kardiološki tim · Poliklinika Dr. Obad</span>
        </div>

        <!-- Display headline -->
        <h1>Specijalistički kardiološki nalaz,<br class="hero-br"> dostupan u vašem mjestu.</h1>

        <p class="hero-lead">
          Holter EKG uređaj u vašoj lokalnoj klinici. Snimak očita
          i potpiše specijalist kardiologije. Bez putovanja u Split ili Zagreb.
        </p>

        <!-- CTAs -->
        <div class="hero-cta-row">
          <a href="/za-partnere" class="btn btn-primary">Postanite partner</a>
          <a href="/za-pacijente" class="btn btn-secondary">Pronađite kliniku u svom mjestu</a>
        </div>
      </div>

      <!-- Right: credential card (desktop only) -->
      <div class="hero-credential-card" aria-hidden="true">
        <div class="cred-header">
          <div class="cred-ecg-line">
            <svg viewBox="0 0 240 48" fill="none" preserveAspectRatio="none">
              <path d="M0 24 H50 L58 8 L68 40 L76 4 L84 44 L90 24 H140 L148 14 L156 36 L162 18 L168 28 L172 24 H240" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="cred-label">Specijalistički nalaz</p>
        </div>

        <div class="cred-specialist">
          <div class="cred-avatar" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="12" r="6" stroke="currentColor" stroke-width="1.5"/>
              <path d="M4 28c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <p class="cred-name">Specijalistički kardiološki tim</p>
            <p class="cred-title">Poliklinika Dr. Obad</p>
          </div>
        </div>

        <div class="cred-divider"></div>

        <div class="cred-metrics">
          <div class="cred-metric">
            <span class="cred-metric-val">24h</span>
            <span class="cred-metric-lbl">monitoring srca</span>
          </div>
          <div class="cred-metric">
            <span class="cred-metric-val">100%</span>
            <span class="cred-metric-lbl">Specijalist osobno pregledava svaki nalaz</span>
          </div>
          <div class="cred-metric">
            <span class="cred-metric-val">HR</span>
            <span class="cred-metric-lbl">mreža partnerskih klinika</span>
          </div>
        </div>

        <div class="cred-footer">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Svaki nalaz potpisuje specijalist kardiologije</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VALUE PILLARS ══════════════════════════════════════════════════ -->
  <section class="section section-muted">
    <div class="container">
      <div class="pillars-heading">
        <p class="section-eyebrow">Što čini razliku</p>
        <h2>Tri stupa kvalitete</h2>
      </div>
      <div class="pillars-grid">
        <div class="pillar">
          <div class="pillar-num">01</div>
          <h3>Specijalistički nalaz</h3>
          <p>
            Svaki snimak pregledava i potpisuje specijalist kardiologije,
            bez delegiranja i bez automatskih izvještaja.
          </p>
        </div>
        <div class="pillar">
          <div class="pillar-num">02</div>
          <h3>Dostupnost u manjim mjestima</h3>
          <p>
            Uređaji su raspoređeni u partnerskim klinikama u područjima u
            kojima kardiološka obrada inače znači cjelodnevni put. Brač,
            Virovitica, Zagreb i drugi.
          </p>
        </div>
        <div class="pillar">
          <div class="pillar-num">03</div>
          <h3>Edukacija osoblja</h3>
          <p>
            Obučavamo medicinsko i ne-medicinsko osoblje partnera za ispravno
            postavljanje i skidanje uređaja. Po potrebi izdajemo certifikat
            osposobljenosti.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container how-section">
      <div class="how-header">
        <p class="section-eyebrow">Tijek pretrage</p>
        <h2>Kako proces izgleda</h2>
        <p class="how-desc">
          Tri koraka. Od dolaska pacijenta u partnersku kliniku do
          preuzimanja potpisanog nalaza.
        </p>
      </div>

      <ol class="steps">
        <li class="step">
          <div class="step-num-wrap">
            <span class="step-num" aria-hidden="true">1</span>
          </div>
          <div class="step-body">
            <h3>Pacijent dolazi u partnersku kliniku</h3>
            <p>
              Osoblje partnera postavlja Holter EKG uređaj. Pacijent ga nosi
              24 sata tijekom svog uobičajenog dana.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-num-wrap">
            <span class="step-num" aria-hidden="true">2</span>
          </div>
          <div class="step-body">
            <h3>Snimak se šalje na specijalističku obradu</h3>
            <p>
              Nakon skidanja, podatci se sigurno prosljeđuju u ustanovu
              na očitanje.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-num-wrap">
            <span class="step-num" aria-hidden="true">3</span>
          </div>
          <div class="step-body">
            <h3>Specijalist potpisuje nalaz</h3>
            <p>
              Pacijent putem partnera preuzima službeni Holter EKG nalaz
              potpisan od specijaliste kardiologije.
            </p>
          </div>
        </li>
      </ol>

      <p class="how-link"><a href="/usluga">Detalji o usluzi →</a></p>
    </div>
  </section>

  <!-- ═══ PARTNER CTA: light blue panel ══════════════════════════════════ -->
  <section class="section partner-cta-band">
    <div class="container partner-cta-inner">
      <div class="partner-cta-text">
        <p class="section-eyebrow">Za ordinacije i klinike</p>
        <h2>Vodite kliniku u manjem mjestu?</h2>
        <p>
          Ponudite pacijentima specijalistički Holter EKG nalaz bez slanja
          u udaljena središta. Mi dostavljamo opremu, obučavamo osoblje i
          preuzimamo očitanje.
        </p>
      </div>
      <div class="partner-cta-action">
        <a href="/za-partnere" class="btn btn-primary">Detalji za partnere</a>
        <a href="/kontakt" class="btn btn-secondary">Kontaktirajte nas</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    background: var(--color-accent);
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .hero { padding-block: var(--space-28); }
  }

  /* Decorative ECG waveform: very subtle, behind content */
  .hero-bg-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    color: var(--color-primary);
    opacity: 0.05;
    pointer-events: none;
  }

  .hero-bg-wave svg { width: 100%; height: 100%; }

  /* Two-column grid on desktop */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr 380px;
      gap: var(--space-16);
    }
  }

  /* Credential badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-primary-light);
    color: var(--color-primary);
    border: 1px solid rgba(20, 87, 164, 0.15);
    border-radius: var(--radius-full);
    padding: 0.3rem 0.875rem;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: var(--space-8);
    max-width: 100%;
  }

  .hero-badge span {
    min-width: 0;
    line-height: 1.35;
  }

  /* Display headline */
  .hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--color-foreground);
    margin: 0 0 var(--space-6);
  }

  @media (min-width: 640px) {
    .hero h1 { font-size: var(--text-5xl); }
  }

  @media (min-width: 960px) {
    .hero h1 { font-size: var(--text-display); }
  }

  .hero-br { display: none; }
  @media (min-width: 640px) { .hero-br { display: block; } }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 38rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero-lead { font-size: var(--text-xl); }
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-10);
    align-items: center;
  }

  /* ── Credential card (desktop right column) ─────────────────────────── */
  .hero-credential-card {
    display: none;
  }

  @media (min-width: 960px) {
    .hero-credential-card {
      display: flex;
      flex-direction: column;
      background: var(--color-background);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-8);
      box-shadow: var(--shadow-lg);
      gap: var(--space-6);
    }
  }

  .cred-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cred-ecg-line {
    height: 48px;
    color: var(--color-primary);
    opacity: 0.7;
  }

  .cred-ecg-line svg { width: 100%; height: 100%; }

  .cred-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.7;
    margin: 0;
  }

  .cred-specialist {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .cred-avatar {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-full);
    background: var(--color-primary-light);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cred-name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    margin: 0 0 var(--space-1);
  }

  .cred-title {
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
    margin: 0;
  }

  .cred-divider {
    height: 1px;
    background: var(--color-border);
  }

  .cred-metrics {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cred-metric {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .cred-metric-val {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    min-width: 3rem;
  }

  .cred-metric-lbl {
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
    line-height: var(--leading-snug);
  }

  .cred-footer {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .cred-footer svg { flex-shrink: 0; }

  /* ── Value pillars ───────────────────────────────────────────────────── */
  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .pillars-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
  }

  .pillar {
    border-top: 2px solid var(--color-primary);
    padding-top: var(--space-5);
  }

  .pillar-num {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
    opacity: 0.7;
  }

  .pillar h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    margin: 0 0 var(--space-3);
    letter-spacing: -0.01em;
  }

  .pillars-heading {
    margin-bottom: var(--space-10);
    max-width: 36rem;
  }

  .pillars-heading h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  @media (min-width: 768px) {
    .pillars-heading h2 { font-size: var(--text-4xl); }
  }

  .pillar p { color: var(--color-muted-foreground); font-size: var(--text-base); margin: 0; }

  /* ── How it works ────────────────────────────────────────────────────── */
  .how-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .how-section {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: start;
    }
    .how-header { position: sticky; top: calc(var(--header-height) + var(--space-8)); }
    .steps { grid-column: 2; }
    .how-link { grid-column: 2; }
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
    opacity: 0.8;
  }

  .how-header h2 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
  }

  .how-desc {
    color: var(--color-muted-foreground);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    max-width: 28rem;
    margin: 0;
  }

  /* Steps */
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .step {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-5);
    align-items: start;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .step:first-child { border-top: 1px solid var(--color-border); }

  .step-num-wrap { padding-top: 0.1rem; }

  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .step-body h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-2);
    color: var(--color-foreground);
  }

  .step-body p { color: var(--color-muted-foreground); margin: 0; font-size: var(--text-base); }

  .how-link {
    margin-top: var(--space-2);
  }

  .how-link a {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .how-link a:hover { text-decoration: underline; }

  /* ── Partner CTA band ───────────────────────────────────────────────── */
  .partner-cta-band {
    background: var(--color-primary-light);
    border-top: 1px solid rgba(20, 87, 164, 0.12);
    border-bottom: 1px solid rgba(20, 87, 164, 0.12);
  }

  .partner-cta-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .partner-cta-inner {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-16);
    }
    .partner-cta-action { justify-self: end; }
  }

  .partner-cta-text .section-eyebrow { margin-bottom: var(--space-3); }

  .partner-cta-text h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-4);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .partner-cta-text h2 { font-size: var(--text-4xl); }
  }

  .partner-cta-text p {
    color: var(--color-muted-foreground);
    max-width: 36rem;
    margin: 0;
    line-height: var(--leading-normal);
  }

  .partner-cta-action {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .partner-cta-action { flex-direction: column; align-items: flex-end; }
  }
</style>
