---
import BaseLayout from '../layouts/BaseLayout.astro';
import PartnerForm from '../components/PartnerForm.astro';

const title = 'Za partnerske klinike';
const description =
  'Ponudite pacijentima Holter EKG nalaz specijalista bez slanja u Split ili Zagreb. Mi dajemo uređaje, obučavamo osoblje i potpisujemo nalaz. Vi ostvarujete novu uslugu i prihod.';
---

<BaseLayout title={title} description={description} path="/za-partnere">

  <!-- ═══ PAGE HERO — B2B specific, compact, authoritative ═════════════════ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-eyebrow">Za ordinacije i klinike · B2B partnerstvo</p>
      <h1>Specijalistički Holter EKG u vašoj ordinaciji — bez ulaganja u opremu.</h1>
      <p class="page-lead">
        Vodite privatnu ordinaciju ili kliniku izvan velikih gradova?
        Ponudite pacijentima specijalistički Holter EKG nalaz koji inače
        zahtijeva put u Split ili Zagreb.
      </p>
    </div>
  </section>

  <!-- ═══ BENTO GRID — što partner dobiva ═════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="bento-header">
        <p class="section-eyebrow">Što partnerska klinika dobiva</p>
        <h2>Kompletan paket bez kapitalnog ulaganja</h2>
      </div>

      <div class="bento-grid">
        <!-- Uređaj -->
        <div class="bento-card bento-card--feature">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 12h2l1.5-3 2 6 1.5-4L15 12h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Holter EKG uređaj na korištenju</h3>
          <p>
            Dostavljamo, postavljamo i mijenjamo prema potrebi.
            Bez kapitalnog ulaganja — oprema ostaje naša, vi je koristite.
          </p>
        </div>

        <!-- Edukacija -->
        <div class="bento-card">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Edukacija osoblja</h3>
          <p>
            Obučavamo medicinsko i ne-medicinsko osoblje.
            Na licu mjesta ili online. Po potrebi certifikat osposobljenosti.
          </p>
        </div>

        <!-- Nalaz -->
        <div class="bento-card">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M7 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.5"/>
              <rect x="7" y="1" width="10" height="4" rx="1" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Specijalist potpisuje svaki nalaz</h3>
          <p>
            Svaki snimak očitava i potpisuje specijalist kardiologije.
            Referentna kvaliteta — vaši pacijenti dobivaju pravi specijalistički nalaz.
          </p>
        </div>

        <!-- Podrška -->
        <div class="bento-card">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
              <path d="M9 9a3 3 0 015.83 1c0 2-3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="12" cy="17" r="0.5" fill="currentColor"/>
            </svg>
          </div>
          <h3>Tehnička podrška i održavanje</h3>
          <p>
            Kvarovi, kalibracija, zamjena uređaja — sve rješavamo mi.
            Vaša klinika ne brinut se o tehničkim problemima.
          </p>
        </div>

        <!-- Prihod -->
        <div class="bento-card bento-card--accent">
          <div class="bento-icon bento-icon--white">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Jasan komercijalni model</h3>
          <p>
            Cijena pretrage za pacijenta je fiksna i transparentna.
            Vi naplaćujete pretragu pacijentu i zadržavate udio koji pokriva vaše
            operativne troškove, postavljanje i skidanje uređaja, prostor, osoblje
            i administraciju.
          </p>
          <p>
            Preostali iznos prepuštate Holterservicu za održavanje uređaja,
            prijenos podataka i specijalističko očitanje nalaza koje potpisuje
            specijalist kardiologije.
          </p>
          <ul class="commercial-highlights" aria-label="Ključne pogodnosti partnerstva">
            <li><strong>Bez kapitalnog ulaganja.</strong></li>
            <li><strong>Bez fiksnih mjesečnih naknada.</strong></li>
            <li>Vi zarađujete na svakoj realiziranoj pretrazi.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KOME ODGOVARA ════════════════════════════════════════════════════ -->
  <section class="section section-muted">
    <div class="container fit-section">
      <div class="fit-text">
        <p class="section-eyebrow">Kome odgovara</p>
        <h2>Pravi partner za ordinacije izvan velikih gradova</h2>
        <p class="fit-desc">
          Naš model je osmišljen za zdravstvene ustanove koje žele proširiti
          ponudu bez ulaganja u skupu opremu i ekspertizu.
        </p>
      </div>

      <ul class="fit-list">
        <li class="fit-item">
          <div class="fit-check">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <strong>Obiteljske ambulante i privatne ordinacije</strong>
            <p>u manjim mjestima, gradićima ili prigradskim područjima</p>
          </div>
        </li>
        <li class="fit-item">
          <div class="fit-check">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <strong>Klinike na otocima i u udaljenim regijama</strong>
            <p>gdje kardiološka dijagnostika inače nije dostupna</p>
          </div>
        </li>
        <li class="fit-item">
          <div class="fit-check">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <strong>Ustanove koje žele proširiti ponudu</strong>
            <p>bez kapitalnog ulaganja u opremu ili zapošljavanja kardiologa</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══ TIJEK SURADNJE ════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="process-header">
        <p class="section-eyebrow">Tijek suradnje</p>
        <h2>Od upita do prvog pacijenta</h2>
      </div>

      <ol class="process-steps">
        <li class="process-step">
          <div class="process-num">01</div>
          <div class="process-body">
            <h3>Pošaljete upit</h3>
            <p>Ispunite formu niže ili pošaljite e-mail. Nema obveza, nema skupih konzultacija.</p>
          </div>
        </li>
        <li class="process-step">
          <div class="process-num">02</div>
          <div class="process-body">
            <h3>Kratki poziv</h3>
            <p>Dogovaramo 15-minutni razgovor da razumijemo lokaciju, volumen i potrebe vaše prakse.</p>
          </div>
        </li>
        <li class="process-step">
          <div class="process-num">03</div>
          <div class="process-body">
            <h3>Ugovor i isporuka</h3>
            <p>Potpisujemo okvirni ugovor i isporučujemo uređaj. Nema skrivenih troškova.</p>
          </div>
        </li>
        <li class="process-step">
          <div class="process-num">04</div>
          <div class="process-body">
            <h3>Edukacija i start</h3>
            <p>Obučavamo vaše osoblje i zajedno primamo prve pacijente. Specijalist potpisuje od prvog nalaza.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═══ FORMA ═════════════════════════════════════════════════════════════ -->
  <PartnerForm heading="Pošaljite upit za partnerstvo" id="partner-form-za-partnere" />
</BaseLayout>

<style>
  /* ── Page hero ───────────────────────────────────────────────────────── */
  .page-hero {
    background: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 768px) {
    .page-hero { padding-block: var(--space-20) var(--space-24); }
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-foreground);
    margin: 0 0 var(--space-5);
    max-width: 42rem;
  }

  @media (min-width: 768px) {
    .page-hero h1 { font-size: var(--text-5xl); }
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 38rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Bento grid header ───────────────────────────────────────────────── */
  .bento-header {
    margin-bottom: var(--space-10);
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
    opacity: 0.8;
  }

  .bento-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 30rem;
  }

  @media (min-width: 768px) {
    .bento-header h2 { font-size: var(--text-4xl); }
  }

  /* ── Bento grid ──────────────────────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .bento-grid { grid-template-columns: repeat(3, 1fr); }
    /* Feature card spans 2 cols */
    .bento-card--feature { grid-column: span 2; }
    /* Accent card spans 2 cols */
    .bento-card--accent { grid-column: span 2; }
  }

  .bento-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: box-shadow 200ms ease, border-color 200ms ease;
  }

  .bento-card:hover {
    box-shadow: var(--shadow-md);
    border-color: rgba(20, 87, 164, 0.2);
  }

  .bento-card--accent {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  /* Chained-class selectors (.bento-card.bento-card--accent) bump
     specificity to (0,2,1) so they win over the generic `.bento-card p`
     rule defined later in source order. WCAG AA on #1457a4 ≈ 8.6:1. */
  .bento-card.bento-card--accent h3 { color: #ffffff; }
  .bento-card.bento-card--accent p { color: #ffffff; }
  .bento-card--accent:hover { border-color: var(--color-primary); }

  .bento-icon {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-primary-light);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .bento-icon--white {
    background: rgba(255, 255, 255, 0.15);
    color: white;
  }

  .bento-card h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-foreground);
  }

  .bento-card p {
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Commercial highlights (inside accent bento card) ────────────────── */
  .commercial-highlights {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .commercial-highlights li {
    position: relative;
    padding-left: var(--space-5);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  /* Checkmark bullet using border-bottom + border-right rotated */
  .commercial-highlights li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.4em;
    width: 0.6rem;
    height: 0.3rem;
    border-left: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(-45deg);
    opacity: 0.9;
  }

  .commercial-highlights li strong {
    font-weight: 600;
  }

  /* On the dark accent card, force pure white for highlighted strong text */
  .bento-card.bento-card--accent .commercial-highlights li strong {
    color: #ffffff;
  }

  /* ── Fit section ─────────────────────────────────────────────────────── */
  .fit-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 900px) {
    .fit-section { grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: start; }
  }

  .fit-text h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
    max-width: 24rem;
  }

  .fit-desc {
    color: var(--color-muted-foreground);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .fit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .fit-item {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .fit-check {
    color: var(--color-primary);
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .fit-item strong {
    display: block;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: var(--space-1);
  }

  .fit-item p {
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
    margin: 0;
    line-height: var(--leading-snug);
  }

  /* ── Process steps ───────────────────────────────────────────────────── */
  .process-header {
    margin-bottom: var(--space-10);
  }

  .process-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 24rem;
  }

  @media (min-width: 768px) {
    .process-header h2 { font-size: var(--text-4xl); }
  }

  .process-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .process-steps { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .process-steps { grid-template-columns: repeat(4, 1fr); }
  }

  .process-step {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .process-num {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    opacity: 0.7;
  }

  .process-body h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-2);
    color: var(--color-foreground);
  }

  .process-body p {
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }
</style>
