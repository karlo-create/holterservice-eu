---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title =
  'Holter KMAT — 24-satno mjerenje krvnog tlaka (ABPM)';
const description =
  'Holter KMAT (ABPM) je 24-satno ambulantno mjerenje krvnog tlaka. Saznajte kome je namijenjeno, kako teče pretraga i kako dolazi do specijalističkog nalaza koji potpisuje specijalist kardiologije.';

const steps = [
  {
    num: '01',
    title: 'Dolazak kod partnera',
    body: 'Naručujete se kod partnerske ustanove koja u svojoj ponudi ima Holter KMAT. Popis vidite na stranici Partneri.',
  },
  {
    num: '02',
    title: 'Postavljanje manžete i uređaja',
    body: 'Educirano osoblje partnera postavlja manžetu na nadlakticu i programira uređaj za 24-satno snimanje.',
  },
  {
    num: '03',
    title: 'Nošenje 24 sata',
    body: 'Uređaj automatski mjeri tlak danju (tipično svakih 15 do 30 minuta) i noću (svakih 30 do 60 minuta). Vodite kratak dnevnik aktivnosti i spavanja.',
  },
  {
    num: '04',
    title: 'Skidanje i slanje podataka',
    body: 'Vraćate se kod partnera, osoblje skida uređaj i sigurno prosljeđuje podatke specijalistu kardiologije.',
  },
  {
    num: '05',
    title: 'Specijalist očitava nalaz',
    body: 'Profil 24-satnog tlaka, dnevno/noćni omjer i jutarnji skok očitava i potpisuje specijalist kardiologije.',
  },
  {
    num: '06',
    title: 'Preuzimanje nalaza',
    body: 'Službeni nalaz preuzimate kod partnera. Standardni rok je 3–5 radnih dana; informirajte se kod partnera za točne uvjete.',
  },
];
---

<BaseLayout title={title} description={description} path="/usluga/holter-kmat">

  <!-- ═══ PAGE HERO ═══════════════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-eyebrow">Usluga · ABPM</p>
      <h1>Holter KMAT, 24-satno mjerenje krvnog tlaka.</h1>
      <p class="page-lead">
        Ambulantno mjerenje krvnog tlaka (ABPM) tijekom 24 sata otkriva
        stvarni profil tlaka koji jednokratno mjerenje u ordinaciji često
        propusti. Pregled obavljate lokalno, nalaz potpisuje specijalist
        kardiologije.
      </p>
    </div>
  </section>

  <!-- ═══ ŠTO JE HOLTER KMAT ══════════════════════════════════════════════ -->
  <section class="section">
    <div class="container what-section">
      <div class="what-text">
        <p class="section-eyebrow">Pretraga</p>
        <h2>Što je Holter KMAT (ABPM)?</h2>
        <p>
          Holter KMAT, poznat i kao ABPM (Ambulatory Blood Pressure
          Monitoring), je 24-satno snimanje krvnog tlaka putem manjeg
          prijenosnog uređaja s manžetom na nadlaktici. Uređaj automatski
          izvodi mjerenja u pravilnim intervalima dok pacijent vodi svoj
          uobičajeni dan i noć.
        </p>
        <p>
          Daje cjelovitu sliku 24-satnog profila tlaka, prosjeke za dnevno i
          noćno razdoblje, varijabilnost i jutarnji skok tlaka. Pomaže
          razlikovati situacije koje jednokratno mjerenje u ordinaciji ne
          razdvaja, npr. hipertenziju bijele kute od stvarne hipertenzije.
        </p>
      </div>
      <div class="what-indications">
        <p class="section-eyebrow">Kome je namijenjen</p>
        <ul class="indication-list">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Sumnja na hipertenziju bijele kute (povišen tlak samo u ordinaciji)
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Sumnja na maskiranu ili sekundarnu hipertenziju
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Evaluacija učinka antihipertenzivne terapije
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Procjena noćnog tlaka i jutarnjeg skoka (non-dipper profil)
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Po preporuci obiteljskog liječnika ili kardiologa
          </li>
        </ul>
        <p class="indication-note">
          Holterservice ne ordinira terapiju, pružamo dijagnostički nalaz
          koji potom koristite kod svog liječnika.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ TEHNOLOGIJA: SCHILLER BR-102 PLUS ═══════════════════════════════ -->
  <section class="section section-muted tech-section-wrap">
    <div class="container tech-section">
      <div class="tech-intro">
        <p class="section-eyebrow">Tehnologija</p>
        <h2>Tehnologija koju koristimo</h2>
        <p>
          Uređaji koje raspoređujemo u partnerske ustanove su
          <strong>SCHILLER BR-102 PLUS</strong>, profesionalni ABPM
          monitori švicarske proizvodnje. Schiller AG je jedan od vodećih
          svjetskih proizvođača kardiološke dijagnostičke opreme, prisutan
          u više od 100 zemalja od 1974. godine.
        </p>
        <p>
          Snimak se analizira u specijalističkom softveru, a finalno
          očitanje i potpis obavlja specijalist kardiologije.
        </p>
      </div>

      <div class="tech-specs">
        <p class="section-eyebrow">Karakteristike važne za kvalitetu nalaza</p>
        <ul class="tech-list">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Hibridna oscilometrijska i auskultacijska tehnika za stabilna mjerenja
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Programabilni intervali mjerenja za dnevno i noćno razdoblje
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Tiho noćno mjerenje koje minimalno remeti san
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Automatska validacija mjerenja i odbacivanje artefakata
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Više veličina manžeta za odraslu populaciju
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══ TIJEK PREGLEDA ════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="steps-header">
        <p class="section-eyebrow">Tijek pregleda</p>
        <h2>Kako teče pretraga, korak po korak</h2>
      </div>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step-card">
            <div class="step-num">{step.num}</div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ KVALITETA NALAZA ═════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container quality-block">
      <div class="quality-quote">
        <blockquote>
          Svaki ABPM snimak ručno pregledava i potpisuje specijalist
          kardiologije, bez delegiranja i bez automatskih izvještaja koji
          mogu propustiti klinički relevantne pojedinosti profila tlaka.
        </blockquote>
        <cite>Holterservice, princip kvalitete</cite>
      </div>
      <div class="quality-detail">
        <p class="section-eyebrow">Kvaliteta nalaza</p>
        <p>
          Cilj nam je da nalaz koji dobijete u partnerskoj klinici bude
          jednake kvalitete kao nalaz koji biste dobili u referentnoj
          ustanovi.
        </p>
        <h3>Što treba ponijeti</h3>
        <ul class="bring-list">
          <li>Uputnicu ili nalaz/zapis liječnika koji vas šalje na pretragu</li>
          <li>Osobnu iskaznicu</li>
          <li>Popis lijekova koje uzimate, uključujući antihipertenzive</li>
        </ul>
        <div class="sla-block" aria-label="Dostupnost">
          <p class="section-eyebrow">Dostupnost</p>
          <p class="sla-availability">
            Holter KMAT je dostupan preko mreže partnera. Točan termin
            i administrativne detalje dogovarate izravno s partnerskom
            ustanovom.
          </p>
          <p class="sla-note">
            Standardni rok nalaza je 3–5 radnih dana od trenutka kad
            uređaj stigne u laboratorij. Informirajte se kod najbližeg
            partnera za točne uvjete.
          </p>
        </div>
        <p class="price-note">
          Informirajte se kod najbližeg partnera za uvjete pretrage.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ════════════════════════════════════════════════════════════ -->
  <section class="section section-muted">
    <div class="container cta-row">
      <a href="/usluga" class="btn btn-secondary">Sve naše usluge</a>
      <a href="/partneri" class="btn btn-primary">Pronađite partnera</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page hero ───────────────────────────────────────────────────────── */
  .page-hero {
    background: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 768px) {
    .page-hero { padding-block: var(--space-20) var(--space-24); }
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 40rem;
    margin: 0 0 var(--space-5);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .page-hero h1 { font-size: var(--text-5xl); }
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 38rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── What section ────────────────────────────────────────────────────── */
  .what-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .what-section { grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: start; }
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
    opacity: 0.8;
  }

  .what-text h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
  }

  .what-text p {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
  }

  .indication-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .indication-list li {
    display: grid;
    grid-template-columns: 1rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-size: var(--text-base);
    color: var(--color-foreground);
  }

  .indication-list svg { color: var(--color-primary); margin-top: 0.125rem; }

  .indication-note {
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
    font-style: italic;
    margin: 0;
    line-height: var(--leading-snug);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  /* ── Tech section ────────────────────────────────────────────────────── */
  .tech-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .tech-section { grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: start; }
  }

  .tech-intro h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
  }

  .tech-intro p {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
  }

  .tech-intro strong {
    color: var(--color-foreground);
    font-weight: 600;
  }

  .tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .tech-list li {
    display: grid;
    grid-template-columns: 1rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-size: var(--text-base);
    color: var(--color-foreground);
    line-height: var(--leading-snug);
  }

  .tech-list svg { color: var(--color-primary); margin-top: 0.125rem; }

  /* ── Steps grid ──────────────────────────────────────────────────────── */
  .steps-header { margin-bottom: var(--space-10); }

  .steps-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  @media (min-width: 768px) {
    .steps-header h2 { font-size: var(--text-4xl); }
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .step-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .step-num {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    opacity: 0.7;
  }

  .step-card h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-foreground);
  }

  .step-card p {
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Quality block ───────────────────────────────────────────────────── */
  .quality-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .quality-block { grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: start; }
  }

  .quality-quote {
    background: var(--color-primary-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
    padding: var(--space-8);
  }

  blockquote {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: var(--leading-snug);
    color: var(--color-foreground);
    margin: 0 0 var(--space-5);
    font-style: italic;
  }

  cite {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.8;
    font-style: normal;
  }

  .quality-detail h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    margin: var(--space-6) 0 var(--space-3);
  }

  .quality-detail p {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: var(--space-3) 0;
  }

  .bring-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .bring-list li {
    padding-left: var(--space-5);
    position: relative;
    font-size: var(--text-base);
    color: var(--color-foreground);
  }

  .bring-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 600;
  }

  .sla-block {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-5);
    margin-top: var(--space-5);
  }

  .sla-block .section-eyebrow { margin-bottom: var(--space-3); }

  .sla-availability {
    color: var(--color-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-3);
  }

  .sla-note {
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .price-note {
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: var(--space-5);
  }

  /* ── CTA ─────────────────────────────────────────────────────────────── */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
