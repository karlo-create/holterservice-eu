---
import BaseLayout from '../layouts/BaseLayout.astro';
import { partners } from '../data/partners';

const title = 'Partnerske klinike';
const description =
  'Popis i mapa partnerskih klinika u kojima možete obaviti Holter EKG pretragu i dobiti specijalistički nalaz potpisan od dr. Obada.';

// LocalBusiness JSON-LD per partner. Empty array OK until founder supplies list.
const partnerJsonLd = partners.map((p) => ({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: p.name,
  address: p.address
    ? {
        '@type': 'PostalAddress',
        streetAddress: p.address,
        addressLocality: p.city,
        addressCountry: 'HR',
      }
    : { '@type': 'PostalAddress', addressLocality: p.city, addressCountry: 'HR' },
  ...(p.phone ? { telephone: p.phone } : {}),
  ...(p.email ? { email: p.email } : {}),
  ...(p.website ? { url: p.website } : {}),
  ...(p.lat && p.lng
    ? { geo: { '@type': 'GeoCoordinates', latitude: p.lat, longitude: p.lng } }
    : {}),
}));
---

<BaseLayout title={title} description={description} path="/partneri">
  {partnerJsonLd.length > 0 && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(partnerJsonLd)}
      slot="head"
    />
  )}

  <!-- ═══ PAGE HERO ═══════════════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-eyebrow">Partneri</p>
      <h1>Gdje obaviti Holter EKG</h1>
      <p class="page-lead">
        Pretragu obavljate u jednoj od partnerskih klinika. Termin i administrativne
        detalje dogovarate izravno s partnerom. Specijalistički nalaz potpisuje dr.
        Obad.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container prose">

      {partners.length === 0 ? (
        <div class="empty-state">
          <div class="empty-state-inner">
            <p class="empty-label">U pripremi</p>
            <h2 class="empty-heading">Prva partnerska mjesta se potvrđuju</h2>
            <p class="empty-body">
              Mreža partnerskih klinika trenutačno se uspostavlja. Svaki partner prolazi
              through uhodavanje s dr. Obadom — tek kad su uređaj, osoblje i protokol
              usklađeni, klinika se uvrštava na popis.
            </p>
            <div class="empty-actions">
              <a href="/za-partnere" class="btn btn-primary">Vodim kliniku — zanima me partnerstvo</a>
              <a href="/kontakt" class="btn btn-secondary">Trebam pretragu odmah</a>
            </div>
          </div>
        </div>
      ) : (
        <ul class="partner-list">
          {partners.map((p) => (
            <li id={p.slug} class="partner card">
              <h2>{p.name}</h2>
              <p class="meta">{p.city}{p.address ? ` · ${p.address}` : ''}</p>
              <ul class="contact">
                {p.phone && (
                  <li>Telefon: <a href={`tel:${p.phone.replace(/\s+/g, '')}`}>{p.phone}</a></li>
                )}
                {p.email && (
                  <li>E-pošta: <a href={`mailto:${p.email}`}>{p.email}</a></li>
                )}
                {p.website && (
                  <li>Web: <a href={p.website} rel="noopener">{p.website}</a></li>
                )}
              </ul>
            </li>
          ))}
        </ul>
      )}

      {partners.length > 0 && (
        <>
          <h2>Mapa partnera</h2>
          <div class="map-placeholder" role="img" aria-label="Mapa partnerskih klinika (uskoro)">
            <p>Interaktivna mapa partnera bit će postavljena kad popis bude potvrđen.</p>
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Page hero ─────────────────────────────────────────────────────── */
  .page-hero {
    background: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 768px) {
    .page-hero { padding-block: var(--space-20) var(--space-24); }
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 var(--space-5);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .page-hero h1 { font-size: var(--text-5xl); }
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 40rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  .eyebrow {
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }
  .lede { font-size: var(--text-lg); color: var(--color-muted-foreground); }

  /* Empty state — intentional anticipation, not broken placeholder */
  .empty-state {
    margin-block: var(--space-12);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-primary-light);
    padding: var(--space-12) var(--space-8);
  }

  .empty-state-inner { max-width: 36rem; }

  .empty-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .empty-label::before {
    content: '';
    display: block;
    width: 1rem;
    height: 1px;
    background: var(--color-primary);
  }

  .empty-heading {
    font-size: var(--text-3xl);
    margin-top: 0;
    margin-bottom: var(--space-4);
    color: var(--color-foreground);
  }

  .empty-body {
    color: var(--color-muted-foreground);
    margin-bottom: var(--space-8);
    line-height: var(--leading-normal);
  }

  .empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .partner-list { list-style: none; padding: 0; display: grid; gap: var(--space-4); }

  @media (min-width: 768px) {
    .partner-list { grid-template-columns: 1fr 1fr; }
  }

  .partner h2 { margin: 0 0 var(--space-2); font-size: var(--text-xl); }
  .partner .meta { color: var(--color-muted-foreground); margin-block: 0; }
  .contact { margin-top: var(--space-3); }

  .map-placeholder {
    margin-top: var(--space-4);
    padding: var(--space-12);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
    color: var(--color-muted-foreground);
    background: var(--color-accent);
  }
</style>
