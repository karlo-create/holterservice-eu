---
import BaseLayout from '../layouts/BaseLayout.astro';
import CroatiaMap from '../components/CroatiaMap.astro';
import {
  partners,
  PARTNER_CITIES,
  PARTNER_TYPE_LABEL,
} from '../data/partners';

const title = 'Naša mreža partnera — Zagreb, Virovitica, Hvar';
const description =
  'Holter EKG pretragu obavljate u partnerskim klinikama u Zagrebu, Virovitici i Hvaru. Specijalistički nalaz potpisuje specijalist kardiologije.';

// LocalBusiness JSON-LD per partner. Empty array OK until founder supplies list.
const partnerJsonLd = partners.map((p) => ({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: p.name,
  address: p.address
    ? {
        '@type': 'PostalAddress',
        streetAddress: p.address,
        addressLocality: p.city,
        addressRegion: p.region,
        addressCountry: 'HR',
      }
    : {
        '@type': 'PostalAddress',
        addressLocality: p.city,
        addressRegion: p.region,
        addressCountry: 'HR',
      },
  ...(p.phone ? { telephone: p.phone } : {}),
  ...(p.email ? { email: p.email } : {}),
  ...(p.website ? { url: p.website } : {}),
  geo: {
    '@type': 'GeoCoordinates',
    latitude: p.coordinates.lat,
    longitude: p.coordinates.lng,
  },
}));

// Map pins: real partners if present, else fall back to placeholder city
// markers so the geographic spread (kontinent / glavni grad / otok) reads
// even before founder supplies the partner contact data.
const mapPins =
  partners.length > 0
    ? partners.map((p) => ({
        slug: p.slug,
        name: p.name,
        city: p.city,
        region: p.region,
        coordinates: p.coordinates,
      }))
    : PARTNER_CITIES.map((c) => ({
        slug: `placeholder-${c.city.toLowerCase()}`,
        city: c.city,
        region: c.region,
        coordinates: c.coordinates,
        placeholder: true,
      }));
---

<BaseLayout title={title} description={description} path="/partneri">
  {partnerJsonLd.length > 0 && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(partnerJsonLd)}
      slot="head"
    />
  )}

  <!-- ═══ PAGE HERO ═══════════════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-eyebrow">Partneri</p>
      <h1>Naša mreža partnera</h1>
      <p class="page-lead">
        Holter EKG pretragu obavljate u jednoj od naših partnerskih klinika diljem
        Hrvatske — od kontinenta do otoka. Termin i administrativne detalje
        dogovarate izravno s partnerom. Specijalistički nalaz potpisuje
        specijalist kardiologije.
      </p>
    </div>
  </section>

  <!-- ═══ MAP ════════════════════════════════════════════════════════════ -->
  <section class="section section-map">
    <div class="container">
      <CroatiaMap pins={mapPins} />
      {partners.length === 0 && (
        <p class="map-note">
          Mreža se uspostavlja u Zagrebu, Virovitici i Hvaru. Detalji svakog
          partnera bit će objavljeni nakon završenog procesa uhodavanja.
        </p>
      )}
    </div>
  </section>

  <!-- ═══ PARTNER CARDS ══════════════════════════════════════════════════ -->
  <section class="section section-partners">
    <div class="container">
      {partners.length > 0 && (
        <p class="demo-banner" role="note">
          <span class="demo-banner-dot" aria-hidden="true"></span>
          Prikazani podaci su demo. Konačni partneri bit će potvrđeni prije pokretanja.
        </p>
      )}
      {partners.length === 0 ? (
        <div class="empty-state">
          <div class="empty-state-inner">
            <p class="empty-label">U pripremi</p>
            <h2 class="empty-heading">Prva partnerska mjesta se potvrđuju</h2>
            <p class="empty-body">
              Mreža partnerskih klinika u Zagrebu, Virovitici i Hvaru trenutačno
              se uspostavlja. Svaki partner prolazi proces uhodavanja sa
              specijalističkim timom — tek kad su uređaj, osoblje i protokol
              usklađeni, klinika se uvrštava na popis.
            </p>
            <div class="empty-actions">
              <a href="/za-partnere" class="btn btn-primary">Vodim kliniku — zanima me partnerstvo</a>
              <a href="/kontakt" class="btn btn-secondary">Trebam pretragu odmah</a>
            </div>
          </div>
        </div>
      ) : (
        <ul class="partner-list">
          {partners.map((p) => (
            <li id={p.slug} class="partner-card">
              <div class="partner-card-head">
                <span class={`partner-badge partner-badge-${p.type}`}>
                  {PARTNER_TYPE_LABEL[p.type]}
                </span>
                <h2 class="partner-name">{p.name}</h2>
                <p class="partner-where">
                  <span class="partner-city">{p.city}</span>
                  <span class="partner-region">{p.region}</span>
                </p>
              </div>

              {p.description && (
                <p class="partner-desc">{p.description}</p>
              )}

              <ul class="partner-contact">
                {p.address && (
                  <li>
                    <span class="contact-label">Adresa</span>
                    <span class="contact-value">{p.address}</span>
                  </li>
                )}
                {p.phone && (
                  <li>
                    <span class="contact-label">Telefon</span>
                    <a class="contact-value" href={`tel:${p.phone.replace(/\s+/g, '')}`}>
                      {p.phone}
                    </a>
                  </li>
                )}
                {p.email && (
                  <li>
                    <span class="contact-label">E-pošta</span>
                    <a class="contact-value" href={`mailto:${p.email}`}>{p.email}</a>
                  </li>
                )}
                {p.website && (
                  <li>
                    <span class="contact-label">Web</span>
                    <a class="contact-value" href={p.website} rel="noopener" target="_blank">
                      {p.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}
                    </a>
                  </li>
                )}
              </ul>

              <div class="partner-cta">
                {p.phone ? (
                  <a class="btn btn-primary" href={`tel:${p.phone.replace(/\s+/g, '')}`}>
                    Naručite se
                  </a>
                ) : p.email ? (
                  <a class="btn btn-primary" href={`mailto:${p.email}`}>
                    Naručite se
                  </a>
                ) : (
                  <a class="btn btn-primary" href="/kontakt">
                    Naručite se
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- ═══ BOTTOM CTA — postanite partner ═════════════════════════════════ -->
  <section class="section section-bottom-cta">
    <div class="container">
      <div class="bottom-cta">
        <h2 class="bottom-cta-heading">Ne vidite svoje mjesto?</h2>
        <p class="bottom-cta-body">
          Holterservice mreža raste. Ako vodite ordinaciju, kliniku, agenciju
          njege u kući ili dom zdravlja u svojoj sredini, javite se. Postanite
          partner.
        </p>
        <div class="bottom-cta-actions">
          <a class="btn btn-primary" href="/za-partnere#kontakt-forma">
            Postanite partner
          </a>
          <a class="btn btn-secondary" href="/za-partnere">
            Saznajte više o partnerstvu
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Page hero ─────────────────────────────────────────────────────── */
  .page-hero {
    background: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 768px) {
    .page-hero { padding-block: var(--space-20) var(--space-24); }
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 var(--space-5);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .page-hero h1 { font-size: var(--text-5xl); }
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 42rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Map section ───────────────────────────────────────────────────── */
  .section-map { padding-block: var(--space-12) var(--space-8); }

  .map-note {
    margin-top: var(--space-6);
    text-align: center;
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
    max-width: 36rem;
    margin-inline: auto;
  }

  /* ── Empty state ───────────────────────────────────────────────────── */
  .empty-state {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-primary-light, var(--color-accent));
    padding: var(--space-12) var(--space-8);
  }

  .empty-state-inner { max-width: 36rem; }

  .empty-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .empty-label::before {
    content: '';
    display: block;
    width: 1rem;
    height: 1px;
    background: var(--color-primary);
  }

  .empty-heading {
    font-size: var(--text-3xl);
    margin-top: 0;
    margin-bottom: var(--space-4);
    color: var(--color-foreground);
  }

  .empty-body {
    color: var(--color-muted-foreground);
    margin-bottom: var(--space-8);
    line-height: var(--leading-normal);
  }

  .empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ── Demo data banner ──────────────────────────────────────────────── */
  .demo-banner {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-6);
    padding: 0.5rem 0.875rem;
    border: 1px dashed var(--color-border);
    border-radius: 9999px;
    background: var(--color-accent);
    color: var(--color-muted-foreground);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  .demo-banner-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.75;
    flex-shrink: 0;
  }

  /* ── Partner cards ─────────────────────────────────────────────────── */
  .partner-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .partner-list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .partner-list { grid-template-columns: repeat(3, 1fr); }
  }

  .partner-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-background);
    padding: var(--space-6);
    transition: box-shadow 200ms ease, border-color 200ms ease;
  }

  .partner-card:hover,
  .partner-card.partner-flash {
    border-color: var(--color-primary);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.05), 0 4px 12px rgb(20 87 164 / 0.08);
  }

  .partner-card.partner-flash {
    animation: partner-flash 1.6s ease-out;
  }

  @keyframes partner-flash {
    0%   { box-shadow: 0 0 0 0 rgb(20 87 164 / 0.35); }
    100% { box-shadow: 0 0 0 12px rgb(20 87 164 / 0); }
  }

  .partner-card-head { margin-bottom: var(--space-4); }

  .partner-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: var(--color-accent);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .partner-name {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
  }

  .partner-where {
    margin: 0;
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
  }

  .partner-city { font-weight: 600; color: var(--color-foreground); }
  .partner-region::before { content: ' · '; }

  .partner-desc {
    color: var(--color-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-5);
  }

  .partner-contact {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    display: grid;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .partner-contact li {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .contact-label {
    color: var(--color-muted-foreground);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .contact-value { color: var(--color-foreground); overflow-wrap: anywhere; }
  a.contact-value { color: var(--color-primary); text-decoration: none; }
  a.contact-value:hover { text-decoration: underline; }

  .partner-cta { margin-top: auto; }

  /* ── Bottom CTA ───────────────────────────────────────────────────── */
  .section-bottom-cta {
    padding-block: var(--space-16) var(--space-20);
    background: var(--color-accent);
    border-top: 1px solid var(--color-border);
  }

  .bottom-cta {
    max-width: 44rem;
    margin-inline: auto;
    text-align: center;
  }

  .bottom-cta-heading {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-4);
    color: var(--color-foreground);
  }

  .bottom-cta-body {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-8);
    font-size: var(--text-lg);
  }

  .bottom-cta-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
