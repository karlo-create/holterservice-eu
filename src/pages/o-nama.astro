---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'O nama — prof. dr. sc. Ante Obad i Poliklinika Dr. Obad';
const description =
  'Iza Holterservice projekta stoji prof. dr. sc. Ante Obad, dr. med., specijalist interne medicine i subspecijalist kardiologije. Poliklinika Dr. Obad u Splitu — nastavna baza Sveučilišta u Splitu.';
---

<BaseLayout title={title} description={description} path="/o-nama">

  <!-- ═══ PAGE HERO ═══════════════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-eyebrow">O nama</p>
      <h1>Specijalistički nalaz, gdje god se nalazite.</h1>
      <p class="page-lead">
        Holterservice je inicijativa prof. dr. sc. Ante Obada, specijalista
        interne medicine i subspecijalista kardiologije, čiji je cilj učiniti
        kvalitetan Holter EKG nalaz dostupnim pacijentima u manjim sredinama —
        bez putovanja u Split, Zagreb ili druga velika središta.
      </p>
    </div>
  </section>

  <!-- ═══ DR. OBAD ═══════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container about-section">
      <div class="about-card">
        <div class="about-card-label">Osnivač i specijalist</div>

        <!-- Photo placeholder — awaiting high-res photo + permission from founder/dr. Obad.
             Backup source: poliklinika-obad.hr/profile/izv-prof-dr-sc-ante-obad-dr-med-spec/ -->
        <figure class="about-photo about-photo--placeholder" aria-hidden="true">
          <svg viewBox="0 0 64 64" width="44" height="44" fill="none">
            <circle cx="32" cy="24" r="11" stroke="currentColor" stroke-width="2"/>
            <path d="M10 56c0-12.15 9.85-22 22-22s22 9.85 22 22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </figure>

        <h2>prof. dr. sc. Ante Obad, dr. med.</h2>
        <p class="about-card-subtitle">
          Specijalist interne medicine · subspecijalist kardiologije ·
          izvanredni profesor, Sveučilišni odjel zdravstvenih studija,
          Sveučilište u Splitu
        </p>
        <p>
          Iza Holterservice projekta stoji prof. dr. sc. Ante Obad, dr. med.,
          specijalist interne medicine i subspecijalist kardiologije,
          izvanredni profesor na Sveučilišnom odjelu zdravstvenih studija
          Sveučilišta u Splitu.
        </p>
        <p>
          Karijeru je gradio kroz Klinički bolnički centar Split i Kliničku
          bolnicu Dubrava. Doktorat iz biomedicine i zdravstva obranio je
          2009. godine s temom iz kardiovaskularne fiziologije. Aktivan je u
          znanosti i visokom obrazovanju kao zamjenik pročelnika
          Sveučilišnog odjela zdravstvenih studija i pomoćnik za inovacije i
          razvoj.
        </p>
      </div>

      <div class="about-context">
        <p class="section-eyebrow">Poliklinika Dr. Obad</p>
        <h2>Vodeća privatna medicinska ustanova u Dalmaciji</h2>
        <p>
          Poliklinika Dr. Obad osnovana je 1995. godine i jedna je od vodećih
          privatnih medicinskih ustanova u Dalmaciji. Osnovao ju je mr. sc.
          Marko Obad, dr. med., a danas je vodi prof. dr. sc. Ante Obad uz
          tim vrhunskih mladih liječnika specijalista.
        </p>
        <p>
          Poliklinika je <strong>nastavna baza Sveučilišta u Splitu,
          Sveučilišnog odjela zdravstvenih studija</strong>. Specijalizirana
          je za kompletnu obradu srca i pruža usluge u području kardiologije,
          gastroenterologije, endokrinologije, reumatologije i drugih grana
          interne medicine.
        </p>
        <p>
          Holterservice projekt nastao je iz želje da se ova razina kvalitete
          učini dostupnom pacijentima izvan Splita, bez putovanja.
        </p>
        <p class="about-outbound">
          <a
            href="https://poliklinika-obad.hr"
            target="_blank"
            rel="noopener"
          >
            Saznajte više o Poliklinici Dr. Obad
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 3h7v7M13 3L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ ZAŠTO OVAJ MODEL ═══════════════════════════════════════════════ -->
  <section class="section section-muted">
    <div class="container about-context about-context--full">
      <p class="section-eyebrow">Zašto ovaj model</p>
      <h2>Kardiološka dijagnostika — dostupna svugdje</h2>
      <p>
        Kardiološka dijagnostika u Hrvatskoj često znači dugotrajno čekanje
        i putovanje u jedan od većih gradova. Za pacijente s otoka i iz
        udaljenih područja to je neproporcionalno opterećenje — vremensko,
        financijsko i zdravstveno.
      </p>
      <p>
        Naš model rješava to tako da opremu i ekspertizu donosimo lokalno.
        Partnerska klinika u vašem mjestu postavlja uređaj, a vrhunski
        specijalistički nalaz dolazi iz Poliklinike Dr. Obad u Splitu.
      </p>
    </div>
  </section>

  <!-- ═══ ŠTO RADIMO / NE RADIMO ════════════════════════════════════════ -->
  <section class="section">
    <div class="container scope-section">
      <div class="scope-col">
        <p class="section-eyebrow">Što radimo</p>
        <ul class="scope-list scope-list--do">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Dajemo Holter EKG uređaje partnerskim klinikama na korištenje.
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Obučavamo osoblje partnera — medicinsko i, prema potrebi, ne-medicinsko.
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Osobno očitavamo i potpisujemo svaki nalaz.
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Održavamo i mijenjamo uređaje.
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Izdajemo certifikat osposobljenosti za rad s uređajem.
          </li>
        </ul>
      </div>

      <div class="scope-col">
        <p class="section-eyebrow">Što ne radimo</p>
        <ul class="scope-list scope-list--dont">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 5l6 6M11 5l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Ne ordiniramo terapiju — to ostaje u rukama vašeg liječnika.
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 5l6 6M11 5l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Ne pružamo hitnu kardiološku obradu.
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 5l6 6M11 5l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Ne organiziramo prijevoz pacijenata.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container cta-row">
      <a href="/usluga" class="btn btn-secondary">Detalji o usluzi</a>
      <a href="/kontakt" class="btn btn-primary">Kontaktirajte nas</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page hero ───────────────────────────────────────────────────────── */
  .page-hero {
    background: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 768px) {
    .page-hero { padding-block: var(--space-20) var(--space-24); }
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 38rem;
    margin: 0 0 var(--space-5);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .page-hero h1 { font-size: var(--text-5xl); }
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 40rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── About section ───────────────────────────────────────────────────── */
  .about-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 900px) {
    .about-section {
      grid-template-columns: 1fr 1.5fr;
      gap: var(--space-16);
      align-items: start;
    }
  }

  /* Dr. Obad card */
  .about-card {
    background: var(--color-primary-light);
    border: 1px solid rgba(20, 87, 164, 0.15);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  .about-card-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
    opacity: 0.8;
  }

  .about-card h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-2);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .about-card h2 { font-size: var(--text-3xl); }
  }

  .about-card-subtitle {
    font-size: var(--text-sm) !important;
    font-weight: 500;
    color: var(--color-primary) !important;
    margin: 0 0 var(--space-5) !important;
    line-height: var(--leading-snug);
    opacity: 0.85;
  }

  .about-card p {
    color: var(--color-muted-foreground);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
  }

  /* Photo (or placeholder while founder provides high-res photo) */
  .about-photo {
    margin: 0 0 var(--space-6);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-background);
    border: 1px solid rgba(20, 87, 164, 0.15);
    aspect-ratio: 1 / 1;
    max-width: 280px;
  }

  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    opacity: 0.35;
  }

  /* Outbound link to Poliklinika Obad */
  .about-outbound {
    margin-top: var(--space-6) !important;
  }

  .about-outbound a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    font-size: var(--text-base);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .about-outbound a:hover { opacity: 0.8; }
  .about-outbound a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .about-outbound svg { flex-shrink: 0; }

  .about-context--full h2 { max-width: 32rem; }

  /* Context text */
  .about-context .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
    opacity: 0.8;
  }

  .about-context h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
    max-width: 28rem;
  }

  .about-context p {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-4);
    max-width: 36rem;
  }

  /* ── Scope section ───────────────────────────────────────────────────── */
  .scope-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 640px) {
    .scope-section { grid-template-columns: 1fr 1fr; gap: var(--space-12); }
  }

  .scope-col .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .scope-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .scope-list li {
    display: grid;
    grid-template-columns: 1rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-foreground);
  }

  .scope-list--do svg { color: var(--color-primary); margin-top: 0.125rem; }
  .scope-list--dont svg { color: var(--color-muted-foreground); margin-top: 0.125rem; }
  .scope-list--dont li { color: var(--color-muted-foreground); }

  /* ── CTA row ─────────────────────────────────────────────────────────── */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: 0;
  }
</style>
