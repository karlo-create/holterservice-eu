---
import BaseLayout from '../layouts/BaseLayout.astro';

const title =
  'Naše usluge — Holter EKG, Holter KMAT (ABPM) i dodatne kardiološke usluge';
const description =
  'Holter EKG (24-satno snimanje rada srca), Holter KMAT (24-satno mjerenje krvnog tlaka, ABPM), video konzultacija s kardiologom i drugo mišljenje. Nalaz potpisuje specijalist kardiologije.';

interface ServiceCard {
  slug: 'holter-ekg' | 'holter-kmat';
  label: string;
  heading: string;
  abbr: string;
  blurb: string;
  bullets: string[];
  href: string;
}

const services: ServiceCard[] = [
  {
    slug: 'holter-ekg',
    label: 'EKG',
    heading: 'Holter EKG',
    abbr: '24-satno snimanje rada srca',
    blurb:
      'Prijenosni uređaj bilježi elektrokardiogram tijekom 24 sata, otkrivajući povremene aritmije i poremećaje provođenja koje standardni EKG u ordinaciji često ne vidi.',
    bullets: [
      'Palpitacije, vrtoglavica, nesvjestica',
      'Praćenje poznatih aritmija',
      'Kontrola nakon ugradnje pacemakera',
    ],
    href: '/usluga/holter-ekg',
  },
  {
    slug: 'holter-kmat',
    label: 'KMAT · ABPM',
    heading: 'Holter KMAT',
    abbr: '24-satno mjerenje krvnog tlaka (ABPM)',
    blurb:
      'Uređaj s manžetom automatski mjeri tlak danju i noću, pokazujući stvarni 24-satni profil koji jednokratno mjerenje u ordinaciji ne razdvaja od situacijskog povišenja tlaka.',
    bullets: [
      'Hipertenzija bijele kute',
      'Sumnja na sekundarnu hipertenziju',
      'Evaluacija učinka antihipertenzivne terapije',
    ],
    href: '/usluga/holter-kmat',
  },
];

const addons = [
  {
    title: 'Video konzultacija s kardiologom',
    body:
      'Nakon nalaza možete dogovoriti online razgovor sa specijalistom kardiologije bez putovanja u Polikliniku. Pojašnjenje nalaza, pitanja, smjernice za daljnje praćenje.',
  },
  {
    title: 'Drugo mišljenje',
    body:
      'Neovisna analiza iste snimke od strane drugog kardiologa s platforme. Dodatna potvrda za važne odluke o terapiji ili daljnjoj obradi.',
  },
];

const addonsMeta =
  'Pruža Poliklinika izravno — dostupno svim pacijentima, neovisno o tome kojeg partnera odaberete za snimanje.';
---

<BaseLayout title={title} description={description} path="/usluga">

  <!-- ═══ PAGE HERO ═══════════════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-eyebrow">Usluge</p>
      <h1>Naše usluge: Holter EKG i Holter KMAT.</h1>
      <p class="page-lead">
        Dvije paralelne dijagnostičke usluge — 24-satno snimanje rada srca
        i 24-satno mjerenje krvnog tlaka — dostupne u partnerskim klinikama
        diljem Hrvatske. Svaki nalaz potpisuje specijalist kardiologije.
      </p>
    </div>
  </section>

  <!-- ═══ PRIMARY SERVICES ════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="services-header">
        <p class="section-eyebrow">Glavne dijagnostičke usluge</p>
        <h2>Dvije paralelne pretrage, isti specijalistički standard</h2>
      </div>

      <ul class="services-grid">
        {services.map((service) => (
          <li class="service-card">
            <div class="service-card-head">
              <span class="service-pill">{service.label}</span>
              <h3 class="service-name">{service.heading}</h3>
              <p class="service-abbr">{service.abbr}</p>
            </div>

            <p class="service-blurb">{service.blurb}</p>

            <p class="service-eyebrow">Tipične indikacije</p>
            <ul class="service-bullets">
              {service.bullets.map((b) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {b}
                </li>
              ))}
            </ul>

            <div class="service-cta">
              <a class="btn btn-primary" href={service.href}>Detalji o pretrazi →</a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══ ADD-ON USLUGE ═══════════════════════════════════════════════════ -->
  <section class="section section-muted" id="dodatne-usluge">
    <div class="container">
      <div class="addons-header">
        <p class="section-eyebrow">Dodatne usluge</p>
        <h2>Nakon nalaza: razgovor s kardiologom ili neovisna provjera</h2>
        <p class="addons-intro">
          Video konzultaciju i drugo mišljenje pruža <strong>Poliklinika izravno</strong> —
          dostupne su svim pacijentima, neovisno o tome kojeg partnera odaberete
          za snimanje.
        </p>
      </div>

      <ul class="addons-grid">
        {addons.map((addon) => (
          <li class="addon-card">
            <h3 class="addon-name">{addon.title}</h3>
            <p class="addon-body">{addon.body}</p>
            <p class="addon-meta">{addonsMeta}</p>
          </li>
        ))}
      </ul>

      <p class="addons-cta">
        <a class="btn btn-secondary" href="/partneri">Pronađite partnera u svom mjestu →</a>
      </p>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS (SHORT) ═══════════════════════════════════════════ -->
  <section class="section">
    <div class="container how-section">
      <div class="how-header">
        <p class="section-eyebrow">Tijek pretrage</p>
        <h2>Tri koraka, ista logika za EKG i KMAT</h2>
        <p class="how-desc">
          Bilo da je riječ o snimanju rada srca ili o 24-satnom mjerenju
          tlaka, model je isti: pretragu obavljate kod partnera, nalaz
          potpisuje specijalist kardiologije.
        </p>
      </div>

      <ol class="steps">
        <li class="step">
          <div class="step-num-wrap">
            <span class="step-num" aria-hidden="true">1</span>
          </div>
          <div class="step-body">
            <h3>Dolazak kod partnera</h3>
            <p>
              Naručujete se izravno kod partnerske klinike. Educirano
              osoblje postavlja uređaj (elektrode za EKG ili manžeta za KMAT)
              i pokreće 24-satno snimanje.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-num-wrap">
            <span class="step-num" aria-hidden="true">2</span>
          </div>
          <div class="step-body">
            <h3>Snimak ide na specijalističku obradu</h3>
            <p>
              Nakon skidanja uređaja podatci se sigurno prosljeđuju u
              ustanovu na očitanje. Snimak analizira specijalist kardiologije.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-num-wrap">
            <span class="step-num" aria-hidden="true">3</span>
          </div>
          <div class="step-body">
            <h3>Potpisani nalaz</h3>
            <p>
              Pacijent preuzima potpisani nalaz kod partnera, obično u
              roku od 3 do 5 radnih dana. Po želji se može dogovoriti
              video konzultacija ili drugo mišljenje.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═══ CTA ════════════════════════════════════════════════════════════ -->
  <section class="section section-muted">
    <div class="container cta-row">
      <a href="/za-pacijente" class="btn btn-secondary">Kako do pretrage</a>
      <a href="/partneri" class="btn btn-primary">Pronađite partnera</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page hero ───────────────────────────────────────────────────────── */
  .page-hero {
    background: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 768px) {
    .page-hero { padding-block: var(--space-20) var(--space-24); }
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-5);
    opacity: 0.8;
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 42rem;
    margin: 0 0 var(--space-5);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .page-hero h1 { font-size: var(--text-5xl); }
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    max-width: 38rem;
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Services grid ───────────────────────────────────────────────────── */
  .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
    opacity: 0.8;
  }

  .services-header {
    margin-bottom: var(--space-10);
    max-width: 36rem;
  }

  .services-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  @media (min-width: 768px) {
    .services-header h2 { font-size: var(--text-4xl); }
  }

  .services-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
  }

  .service-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .service-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .service-card-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .service-pill {
    align-self: flex-start;
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  .service-name {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    margin: 0;
  }

  @media (min-width: 768px) {
    .service-name { font-size: var(--text-3xl); }
  }

  .service-abbr {
    font-size: var(--text-base);
    color: var(--color-muted-foreground);
    margin: 0;
    line-height: var(--leading-snug);
  }

  .service-blurb {
    color: var(--color-foreground);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .service-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.7;
    margin: 0;
  }

  .service-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .service-bullets li {
    display: grid;
    grid-template-columns: 1rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-size: var(--text-sm);
    color: var(--color-foreground);
    line-height: var(--leading-snug);
  }

  .service-bullets svg {
    color: var(--color-primary);
    margin-top: 0.2rem;
  }

  .service-cta {
    margin-top: auto;
    padding-top: var(--space-3);
  }

  /* ── Addons ──────────────────────────────────────────────────────────── */
  .addons-header {
    margin-bottom: var(--space-10);
    max-width: 42rem;
  }

  .addons-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-4);
  }

  @media (min-width: 768px) {
    .addons-header h2 { font-size: var(--text-4xl); }
  }

  .addons-intro {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .addons-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .addons-grid { grid-template-columns: 1fr 1fr; }
  }

  .addon-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .addon-name {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-foreground);
  }

  .addon-body {
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .addon-meta {
    margin: var(--space-2) 0 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-muted-foreground);
    font-style: italic;
  }

  .addons-cta {
    margin: 0;
  }

  /* ── How section ─────────────────────────────────────────────────────── */
  .how-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 900px) {
    .how-section {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: start;
    }
    .how-header { position: sticky; top: calc(var(--header-height) + var(--space-8)); }
    .steps { grid-column: 2; }
  }

  .how-header h2 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5);
  }

  .how-desc {
    color: var(--color-muted-foreground);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    max-width: 28rem;
    margin: 0;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .step {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-5);
    align-items: start;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .step:first-child { border-top: 1px solid var(--color-border); }

  .step-num-wrap { padding-top: 0.1rem; }

  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .step-body h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-2);
    color: var(--color-foreground);
  }

  .step-body p { color: var(--color-muted-foreground); margin: 0; font-size: var(--text-base); }

  /* ── CTA ─────────────────────────────────────────────────────────────── */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
