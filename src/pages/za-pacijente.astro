---
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import { patientFaq, buildFaqJsonLd } from '../data/faq';

const title = 'Za pacijente';
const description =
  'Kako do Holter EKG ili Holter KMAT (24-satno mjerenje krvnog tlaka) nalaza specijalista preko partnerske klinike u vašem mjestu. Saznajte što ponijeti, kako teče pretraga i kada očekivati nalaz.';

const faqJsonLd = JSON.stringify(buildFaqJsonLd(patientFaq));
---

<BaseLayout title={title} description={description} path="/za-pacijente">
  <script slot="head" type="application/ld+json" set:html={faqJsonLd} />
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">Za pacijente</p>
      <h1>Kako do nalaza preko partnerske klinike</h1>
      <p class="lede">
        Pretraga je dostupna u partnerskim klinikama, najčešće u manjim mjestima i
        otocima, bez potrebe za putovanjem u Split, Zagreb ili druga središta.
        Dostupne su dvije paralelne pretrage — <strong>Holter EKG</strong>
        (24-satno snimanje rada srca) i <strong>Holter KMAT</strong>
        (24-satno mjerenje krvnog tlaka, ABPM). Nalaz potpisuje specijalist
        kardiologije.
      </p>

      <h2>1. Pronađite partnera u svom mjestu</h2>
      <p>
        Popis partnerskih klinika nalazi se na stranici <a href="/partneri">Partneri</a>.
        {/* PLACEHOLDER: kad founder dostavi popis, ovaj odjeljak će linkati na konkretne klinike */}
      </p>

      <h2>2. Naručite se</h2>
      <p>
        Naručivanje obavljate izravno kod partnerske klinike, telefonom ili e-mailom.
        Mi ne vodimo centralni raspored. Termin i sve administrativne detalje
        dogovara partner.
      </p>

      <h2>3. Što ponijeti na pregled</h2>
      <ul>
        <li>Uputnicu ili medicinsku dokumentaciju liječnika koji vas šalje.</li>
        <li>Osobnu iskaznicu.</li>
        <li>Popis lijekova koje uzimate.</li>
        <li>Praktičnu odjeću. Gornji dio bi trebao biti lako dostupan radi
          postavljanja elektroda.</li>
      </ul>

      <h2>4. Pretraga traje 24 sata</h2>
      <p>
        Educirano osoblje partnera postavlja uređaj (elektrode za Holter EKG
        ili manžeta za Holter KMAT). Cijeli dan obavljate svoje uobičajene
        aktivnosti. Uređaj je lagan i ne ometa kretanje. Vodite kratak
        dnevnik. Kad ste spavali, kad osjetili neki simptom, kad ste vježbali.
      </p>
      <p>
        Za 24-satno mjerenje krvnog tlaka (Holter KMAT / ABPM) uređaj
        automatski mjeri tlak u intervalima danju i noću, pa ne morate
        ništa ručno bilježiti vezano uz tlak — dovoljno je da nastavite
        svoj uobičajen dan.
      </p>
      <p>
        <strong>Nemojte:</strong> tuširati se ili kupati s uređajem, osim ako vas
        partner izričito uputi drugačije.
      </p>

      <h2>5. Skidanje i očitanje</h2>
      <p>
        Vraćate uređaj u kliniku, partner skida elektrode i prosljeđuje snimak
        na specijalističku obradu. Nalaz očitava i potpisuje specijalist
        kardiologije.
      </p>

      <h2>6. Preuzimanje nalaza</h2>
      <p>
        Službeni nalaz dobivate od partnerske klinike u roku od
        <strong>3–5 radnih dana</strong> od trenutka kad uređaj stigne u
        laboratorij Poliklinike Dr. Obad. Nalaz pokažete svom obiteljskom
        liječniku ili kardiologu radi daljnjeg vođenja.
      </p>
      <p>
        Po potrebi je dostupan i <strong>hitan nalaz unutar 24 h</strong>,
        uz dodatnu cijenu — dogovara se s partnerskom klinikom pri naručivanju.
      </p>

      <h2>7. Razgovor s kardiologom nakon nalaza (po potrebi)</h2>
      <p>
        Nakon što ste preuzeli nalaz, kroz mrežu partnera dostupna je
        i <strong>video konzultacija s kardiologom</strong> — online razgovor
        sa specijalistom bez putovanja u Polikliniku. Korisno za pojašnjenje
        nalaza i smjernice za daljnje praćenje. Ako vam je važno dodatno
        sigurno, dostupna je i usluga <strong>drugog mišljenja</strong>
        — neovisna analiza iste snimke od drugog kardiologa s platforme.
      </p>
      <p>
        O obje dodatne usluge informirajte se kod najbližeg partnera.
      </p>

      <h2>Cijena</h2>
      <p>
        Cijenu i način plaćanja određuje partnerska klinika. Za točan iznos
        kontaktirajte odabranog partnera.
      </p>

      <div class="next-step">
        <p class="section-eyebrow">Sljedeći korak</p>
        <h2>Što vam je sljedeći korak?</h2>
        <div class="next-step-grid">
          <a
            href="/partneri"
            class="next-step-card"
            data-event="patient_partner_card_click"
            data-partner="cta_imate_preporuku"
          >
            <p class="next-step-card-body">
              Imate preporuku liječnika za Holter EKG i tražite gdje ga obaviti?
            </p>
            <p class="next-step-card-cta">Pronađite partnera u svom mjestu →</p>
          </a>
          <a
            href="/kontakt"
            class="next-step-card"
          >
            <p class="next-step-card-body">
              Niste sigurni gdje vam je najbliži partner ili imate dodatno pitanje?
            </p>
            <p class="next-step-card-cta">Kontaktirajte nas →</p>
          </a>
        </div>
      </div>

      <div class="cta-block">
        <a href="/usluga" class="btn btn-secondary">Što je Holter EKG</a>
      </div>
    </div>
  </section>

  <Faq
    id="faq"
    eyebrow="Česta pitanja"
    heading="Što pacijenti najčešće pitaju"
    items={patientFaq}
  />
</BaseLayout>

<style>
  .eyebrow {
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }
  .lede { font-size: var(--text-lg); color: var(--color-muted-foreground); }
  .cta-block { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-10); }

  .next-step {
    margin-top: var(--space-16);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
  }
  .next-step .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
    opacity: 0.8;
  }
  .next-step h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-8);
    color: var(--color-foreground);
  }
  .next-step-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .next-step-grid { grid-template-columns: 1fr 1fr; }
  }
  .next-step-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: var(--color-foreground);
    transition: border-color 200ms ease, box-shadow 200ms ease;
    min-height: 12rem;
  }
  .next-step-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }
  .next-step-card-body {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-foreground);
    margin: 0;
  }
  .next-step-card-cta {
    font-weight: 600;
    color: var(--color-primary);
    font-size: var(--text-base);
    margin: 0;
  }
</style>
