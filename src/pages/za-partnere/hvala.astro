---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Hvala na upitu — Holterservice';
const description =
  'Vaš upit za partnerstvo s Holterservice je zaprimljen. Javljamo se unutar 24 sata radnim danom.';

// Cal.com link is env-configurable so PM/founder can swap once the real
// event URL exists (see PLACEHOLDERS.md).
const calLink = import.meta.env.PUBLIC_CAL_LINK ?? 'https://cal.com/holterservice';
const supportEmail = 'partneri@holterservice.eu';
---

<BaseLayout title={title} description={description} path="/za-partnere/hvala">
  <Fragment slot="head">
    <!-- Don't index the thank-you page. -->
    <meta name="robots" content="noindex,follow" />
  </Fragment>

  <section class="thanks-hero">
    <div class="container">
      <div class="thanks-card">
        <div class="thanks-badge" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
            <path
              d="M5 12.5l4.5 4.5L19 7"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>

        <p class="page-eyebrow">Upit zaprimljen</p>
        <h1>Hvala na upitu!</h1>
        <p class="lead">
          Vaš upit za partnerstvo je zaprimljen. Javit ćemo vam se
          <strong>unutar 24 sata radnim danom</strong> radi dogovora kratkog
          razgovora.
        </p>

        <div class="cal-block">
          <h2>Želite ubrzati proces?</h2>
          <p>
            Rezervirajte 15-minutni razgovor odmah u terminu koji vam odgovara.
          </p>
          <a
            class="btn btn-primary"
            href={calLink}
            target="_blank"
            rel="noopener noreferrer"
            data-cal-link
          >
            Rezerviraj 15-min razgovor
          </a>
        </div>

        <div class="contact-row">
          <div class="contact-cell">
            <h3>Imate hitno pitanje?</h3>
            <p>
              Pošaljite e-mail na
              <a href={`mailto:${supportEmail}`}>{supportEmail}</a>.
              Telefon objavljujemo uskoro.
            </p>
          </div>
          <div class="contact-cell">
            <h3>Što sljedeće?</h3>
            <p>
              Poslat ćemo vam potvrdni e-mail. Provjerite i mapu
              <em>spam</em> ako se ne pojavi u inboxu unutar nekoliko minuta.
            </p>
          </div>
        </div>

        <p class="back-link">
          <a href="/za-partnere">← Natrag na stranicu za partnere</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  type Plausible = (
    event: string,
    opts?: { props?: Record<string, unknown> }
  ) => void;
  declare global {
    interface Window {
      plausible?: Plausible;
    }
  }

  // Fire the thank-you view event and wire the calendar button click.
  try {
    window.plausible?.('partner_form_thank_you_view');
  } catch {
    /* no-op */
  }

  document
    .querySelectorAll<HTMLAnchorElement>('[data-cal-link]')
    .forEach((a) => {
      a.addEventListener('click', () => {
        try {
          window.plausible?.('partner_calendar_book_click');
        } catch {
          /* no-op */
        }
      });
    });
</script>

<style>
  .thanks-hero {
    background: var(--color-accent);
    padding-block: var(--space-20) var(--space-24);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .thanks-card {
    max-width: 44rem;
    margin-inline: auto;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: var(--space-10) var(--space-8);
  }

  @media (min-width: 768px) {
    .thanks-card { padding: var(--space-12) var(--space-12); }
  }

  .thanks-badge {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-6);
  }

  .page-eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-4);
    opacity: 0.85;
  }

  .thanks-card h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-foreground);
    margin: 0 0 var(--space-4);
  }

  @media (min-width: 768px) {
    .thanks-card h1 { font-size: var(--text-5xl); }
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--color-muted-foreground);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-8);
  }

  .cal-block {
    background: var(--color-primary-light);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .cal-block h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-foreground);
  }

  .cal-block p {
    color: var(--color-muted-foreground);
    margin: 0;
  }

  .cal-block .btn { align-self: flex-start; }

  .contact-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .contact-row { grid-template-columns: 1fr 1fr; gap: var(--space-6); }
  }

  .contact-cell h3 {
    font-size: var(--text-base);
    font-weight: 600;
    margin: 0 0 var(--space-2);
    color: var(--color-foreground);
  }

  .contact-cell p {
    color: var(--color-muted-foreground);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .back-link {
    margin-top: var(--space-8);
    font-size: var(--text-sm);
  }

  .back-link a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link a:hover { text-decoration: underline; }
</style>
